[
  {
    "description": "url and explicit name preserved, no headers",
    "stream": { "name": "VidRock 1080p", "title": "The Movie", "url": "https://vid/x.mkv" },
    "expected_url": "https://vid/x.mkv",
    "expected_name": "VidRock 1080p",
    "expected_has_proxy_headers": false
  },
  {
    "description": "name falls back to quality",
    "stream": { "url": "https://vid/2.mkv", "quality": "2160p" },
    "expected_url": "https://vid/2.mkv",
    "expected_name": "2160p",
    "expected_has_proxy_headers": false
  },
  {
    "description": "headers become proxyHeaders",
    "stream": { "name": "Source", "url": "https://vid/3.mkv", "headers": { "Referer": "https://ref", "User-Agent": "UA" } },
    "expected_url": "https://vid/3.mkv",
    "expected_name": "Source",
    "expected_has_proxy_headers": true
  },
  {
    "description": "no name and no quality leaves the label empty",
    "stream": { "url": "https://vid/4.mkv" },
    "expected_url": "https://vid/4.mkv",
    "expected_name": null,
    "expected_has_proxy_headers": false
  }
]
