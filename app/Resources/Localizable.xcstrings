        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaši profili, nastavitve in ključi metapodatkov se sinhronizirajo s tem računom, šifrirano od konca do konca. Sinhronizirajo se tudi samodejno trenutek po vsaki spremembi."
          }
