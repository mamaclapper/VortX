    "Install the new build from the GitHub releases page; your sign-in and settings carry over.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Installa la nuova versione dalla pagina delle release di GitHub; il tuo accesso e le impostazioni vengono mantenuti."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Instala la nueva versión desde la página de releases de GitHub; tu inicio de sesión y ajustes se conservan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Installez la nouvelle version depuis la page des releases GitHub ; votre connexion et vos réglages sont conservés."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Installiere den neuen Build von der GitHub-Releases-Seite; deine Anmeldung und Einstellungen werden übernommen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Instale a nova versão pela página de releases do GitHub; seu login e configurações são mantidos."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub のリリースページから新しいビルドをインストールしてください。サインインと設定は引き継がれます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub 릴리스 페이지에서 새 빌드를 설치하세요. 로그인과 설정은 그대로 유지됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从 GitHub 发布页安装新构建版本；你的登录和设置会随之保留。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Установите новую сборку со страницы релизов GitHub; ваш вход и настройки сохранятся."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub रिलीज़ पेज से नया बिल्ड इंस्टॉल करें; आपका साइन-इन और सेटिंग्स साथ चली आती हैं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ثبّت الإصدار الجديد من صفحة الإصدارات على GitHub؛ تنتقل معك بيانات تسجيل دخولك وإعداداتك."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yeni sürümü GitHub sürümler sayfasından yükleyin; oturumunuz ve ayarlarınız aktarılır."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Instale a nova versão a partir da página de lançamentos do GitHub; a sua sessão e definições transitam."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Installeer de nieuwe build vanaf de GitHub-releasepagina; je aanmelding en instellingen blijven behouden."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zainstaluj nową kompilację ze strony wydań GitHub; Twoje logowanie i ustawienia zostaną zachowane."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Installera det nya bygget från GitHub-utgivningssidan; din inloggning och dina inställningar följer med."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請從 GitHub releases 頁面安裝新版本；你的登入與設定都會保留。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Instal build baru dari halaman rilis GitHub; info masuk dan pengaturan Anda ikut terbawa."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ติดตั้งบิลด์ใหม่จากหน้า GitHub releases การลงชื่อเข้าใช้และการตั้งค่าของคุณจะถูกนำมาด้วย"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Cài đặt bản dựng mới từ trang releases trên GitHub; thông tin đăng nhập và cài đặt của bạn sẽ được giữ lại."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Установіть нову збірку зі сторінки релізів GitHub; ваш вхід і налаштування переносяться."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nainstalujte novou verzi ze stránky vydání na GitHubu; vaše přihlášení a nastavení se přenesou."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Εγκαταστήστε τη νέα έκδοση από τη σελίδα εκδόσεων του GitHub· η σύνδεση και οι ρυθμίσεις σας μεταφέρονται."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "התקן את הגרסה החדשה מדף ההפצות ב-GitHub; ההתחברות וההגדרות שלך עוברות יחד."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Installér den nye build fra GitHub-udgivelsessiden; din login og dine indstillinger følger med."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Asenna uusi versio GitHubin julkaisusivulta; kirjautumisesi ja asetuksesi siirtyvät mukana."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Installer den nye versjonen fra utgivelsessiden på GitHub; innloggingen og innstillingene dine følger med."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Instalează noua versiune din pagina de lansări GitHub; autentificarea și setările tale se păstrează."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Telepítsd az új buildet a GitHub kiadások oldaláról; a bejelentkezésed és a beállításaid átkerülnek."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pasang binaan baharu daripada halaman keluaran GitHub; log masuk dan tetapan anda dibawa bersama."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "I-install ang bagong build mula sa pahina ng mga release sa GitHub; sumasama ang iyong sign-in at mga setting."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "نسخه جدید را از صفحه انتشارها در GitHub نصب کنید؛ ورود و تنظیمات شما منتقل می‌شوند."
          }
        }
      }
    },
    "Keeps its own watch history, synced through your Stremio account to your other devices.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantiene la propria cronologia di visione, sincronizzata tramite il tuo account Stremio sugli altri dispositivi."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantiene su propio historial de visualización, sincronizado a través de tu cuenta Stremio en tus otros dispositivos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Conserve son propre historique de visionnage, synchronisé via votre compte Stremio vers vos autres appareils."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Behält einen eigenen Wiedergabeverlauf, der über dein Stremio-Konto mit deinen anderen Geräten synchronisiert wird."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantém o próprio histórico de exibição, sincronizado pela sua conta Stremio com os seus outros dispositivos."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "独自の視聴履歴を保持し、Stremio アカウントを通じて他のデバイスに同期します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "자체 시청 기록을 유지하며, Stremio 계정을 통해 다른 기기와 동기화됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保留它自己的观看历史，通过你的 Stremio 账户同步到你的其他设备。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ведёт собственную историю просмотра, синхронизируемую через ваш аккаунт Stremio с другими устройствами."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपना खुद का देखने का इतिहास रखता है, जो आपके Stremio खाते के ज़रिए आपके अन्य डिवाइसों में सिंक होता है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحتفظ بسجل مشاهدته الخاص، مُزامَنًا عبر حساب Stremio الخاص بك إلى أجهزتك الأخرى."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Stremio hesabınız aracılığıyla diğer cihazlarınıza eşitlenen, kendi izleme geçmişini tutar."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantém o seu próprio histórico de visualização, sincronizado através da sua conta Stremio com os seus outros dispositivos."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Houdt zijn eigen kijkgeschiedenis bij, gesynchroniseerd via je Stremio-account naar je andere apparaten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zachowuje własną historię oglądania, synchronizowaną przez Twoje konto Stremio z innymi urządzeniami."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Behåller sin egen tittarhistorik, synkad via ditt Stremio-konto till dina andra enheter."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "保有自己的觀看記錄，並透過你的 Stremio 帳號同步至你的其他裝置。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Menyimpan riwayat tontonnya sendiri, disinkronkan melalui akun Stremio Anda ke perangkat lain."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เก็บประวัติการดูของตัวเอง ซิงค์ผ่านบัญชี Stremio ของคุณไปยังอุปกรณ์อื่น"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Giữ lịch sử xem riêng, được đồng bộ qua tài khoản Stremio của bạn tới các thiết bị khác."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Веде власну історію перегляду, синхронізовану через ваш акаунт Stremio з іншими пристроями."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Uchovává si vlastní historii sledování, synchronizovanou přes váš účet Stremio do ostatních zařízení."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Διατηρεί το δικό του ιστορικό παρακολούθησης, συγχρονισμένο μέσω του λογαριασμού Stremio σας με τις άλλες συσκευές σας."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "שומרת היסטוריית צפייה משלה, מסונכרנת דרך חשבון Stremio שלך למכשירים האחרים שלך."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Beholder sin egen seehistorik, synkroniseret via din Stremio-konto til dine andre enheder."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Säilyttää oman katseluhistoriansa, joka synkronoidaan Stremio-tilisi kautta muihin laitteisiisi."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Beholder sin egen avspillingshistorikk, synkronisert gjennom Stremio-kontoen din til de andre enhetene dine."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Își păstrează propriul istoric de vizionare, sincronizat prin contul tău Stremio cu celelalte dispozitive."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Saját megtekintési előzményeket vezet, amelyek a Stremio-fiókodon keresztül szinkronizálódnak a többi eszközödre."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Mengekalkan sejarah tontonannya sendiri, disegerakkan melalui akaun Stremio anda ke peranti lain anda."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Pinapanatili ang sarili nitong watch history, naka-sync sa pamamagitan ng iyong Stremio account sa iyong ibang mga device."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "تاریخچه تماشای خودش را نگه می‌دارد که از طریق حساب Stremio شما با دستگاه‌های دیگرتان همگام می‌شود."
          }
        }
      }
    },
