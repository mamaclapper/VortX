        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Opsyonal. Ang isang libre at end-to-end-encrypted na account ay nag-iingat ng iyong mga profile, setting, at library nang ligtas sa iba't ibang device."
          }
