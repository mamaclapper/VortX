            "value": "Selecionar = escolher outra fonte    ·    Reproduzir/Pausar = tentar de novo    ·    Menu = voltar"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecteren = kies een andere bron    ·    Afspelen/Pauzeren = opnieuw proberen    ·    Menu = terug"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Select = wybierz inne źródło    ·    Odtwórz/Pauza = ponów    ·    Menu = wstecz"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Välj = välj en annan källa    ·    Spela/Pausa = försök igen    ·    Meny = tillbaka"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Select＝選擇其他來源    ·    播放/暫停＝重試    ·    選單＝返回"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Select = pilih sumber lain    ·    Play/Pause = coba lagi    ·    Menu = kembali"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "Select = เลือกแหล่งอื่น    ·    Play/Pause = ลองอีกครั้ง    ·    Menu = ย้อนกลับ"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Select = chọn nguồn khác    ·    Play/Pause = thử lại    ·    Menu = quay lại"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Select = вибрати інше джерело    ·    Play/Pause = повторити    ·    Menu = назад"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Select = zvolit jiný zdroj    ·    Přehrát/Pozastavit = zkusit znovu    ·    Menu = zpět"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Select = επιλογή άλλης πηγής    ·    Play/Pause = επανάληψη    ·    Menu = πίσω"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "Select = בחר מקור אחר    ·    Play/Pause = נסה שוב    ·    Menu = חזרה"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vælg = vælg en anden kilde    ·    Afspil/Pause = prøv igen    ·    Menu = tilbage"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Valitse = valitse toinen lähde    ·    Toista/Tauko = yritä uudelleen    ·    Valikko = takaisin"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Velg = velg en annen kilde    ·    Spill/Pause = prøv igjen    ·    Meny = tilbake"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Select = alege altă sursă    ·    Play/Pauză = reîncearcă    ·    Meniu = înapoi"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Kiválasztás = másik forrás választása    ·    Lejátszás/Szünet = újrapróbálkozás    ·    Menü = vissza"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih = pilih sumber lain    ·    Main/Jeda = cuba semula    ·    Menu = kembali"
          }
        },
        "fil": {
