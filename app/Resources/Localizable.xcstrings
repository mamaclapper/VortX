        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Налепите URL адресе манифеста додатака, једну по реду, па их све инсталирајте у једном кораку."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Prilepite URL-je manifestov dodatkov, enega na vrstico, nato pa jih namestite vse v enem koraku."
