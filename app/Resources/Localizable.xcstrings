        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Вхід підтягує ваші додатки та бібліотеку в застосунок. Ваш акаунт лишається на цьому пристрої."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přihlášení načte vaše doplňky a knihovnu do aplikace. Váš účet zůstává v tomto zařízení."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η σύνδεση φέρνει τα πρόσθετα και τη βιβλιοθήκη σας στην εφαρμογή. Ο λογαριασμός σας παραμένει σε αυτή τη συσκευή."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "התחברות מושכת את ההרחבות והספרייה שלך לאפליקציה. החשבון שלך נשאר במכשיר הזה."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Når du logger ind, hentes dine tilføjelser og dit bibliotek ind i appen. Din konto bliver på denne enhed."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kirjautuminen tuo lisäosasi ja kirjastosi sovellukseen. Tilisi pysyy tällä laitteella."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Innlogging henter tilleggene og biblioteket ditt inn i appen. Kontoen din blir på denne enheten."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Autentificarea aduce add-on-urile și biblioteca în aplicație. Contul tău rămâne pe acest dispozitiv."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A bejelentkezés behúzza a kiegészítőidet és a könyvtáradat az appba. A fiókod ezen az eszközön marad."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Log masuk menarik tambahan dan pustaka anda ke dalam aplikasi. Akaun anda kekal pada peranti ini."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Ang pag-sign in ay nagdadala ng iyong mga add-on at library sa app. Nananatili sa device na ito ang iyong account."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "ورود به حساب، افزونه‌ها و کتابخانه شما را به برنامه می‌آورد. حساب شما روی این دستگاه می‌ماند."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সাইন ইন করলে আপনার অ্যাড-অন এবং লাইব্রেরি অ্যাপে চলে আসে। আপনার অ্যাকাউন্ট এই ডিভাইসেই থাকে।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "உள்நுழைவது உங்கள் நீட்சிகளையும் லைப்ரரியையும் ஆப்பில் கொண்டுவரும். உங்கள் கணக்கு இந்தச் சாதனத்திலேயே இருக்கும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "సైన్ ఇన్ చేయడం వల్ల మీ యాడ్-ఆన్‌లు మరియు లైబ్రరీ యాప్‌లోకి వస్తాయి. మీ ఖాతా ఈ పరికరంలోనే ఉంటుంది."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "साइन इन केल्याने तुमचे add-ons आणि लायब्ररी अॅपमध्ये येतात. तुमचे खाते या डिव्हाइसवरच राहते."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "સાઇન ઇન કરવાથી તમારા add-ons અને library એપમાં ખેંચાય છે. તમારું account આ ઉપકરણ પર રહે છે."
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಸೈನ್ ಇನ್ ಮಾಡುವುದರಿಂದ ನಿಮ್ಮ ಆಡ್-ಆನ್‌ಗಳು ಮತ್ತು ಲೈಬ್ರರಿಯನ್ನು ಆ್ಯಪ್‌ಗೆ ಎಳೆಯುತ್ತದೆ. ನಿಮ್ಮ ಖಾತೆ ಈ ಸಾಧನದಲ್ಲಿ ಉಳಿಯುತ್ತದೆ."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "സൈൻ ഇൻ ചെയ്യുന്നത് നിങ്ങളുടെ ആഡ്-ഓണുകളും ലൈബ്രറിയും ആപ്പിലേക്ക് കൊണ്ടുവരുന്നു. നിങ്ങളുടെ അക്കൗണ്ട് ഈ ഉപകരണത്തിൽ തന്നെ തുടരുന്നു."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "سائن اِن کرنے سے آپ کے ایڈ-آنز اور لائبریری ایپ میں آ جاتے ہیں۔ آپ کا اکاؤنٹ اسی ڈیوائس پر رہتا ہے۔"
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Prihlásenie načíta vaše doplnky a knižnicu do aplikácie. Váš účet zostáva v tomto zariadení."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Влизането изтегля вашите добавки и библиотека в приложението. Вашият акаунт остава на това устройство."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prijava povlači vaše dodatke i biblioteku u aplikaciju. Vaš račun ostaje na ovom uređaju."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Пријава учитава ваше додатке и библиотеку у апликацију. Ваш налог остаје на овом уређају."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Prijava prenese vaše dodatke in knjižnico v aplikacijo. Vaš račun ostane v tej napravi."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Prisijungus jūsų papildiniai ir biblioteka įkeliami į programą. Jūsų paskyra lieka šiame įrenginyje."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Pierakstoties, jūsu papildinājumi un bibliotēka tiek ievilkti lietotnē. Jūsu konts paliek šajā ierīcē."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Sisselogimine toob su lisad ja teegi rakendusse. Su konto jääb sellesse seadmesse."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Iniciar sessió importa els teus complements i biblioteca a l'app. El teu compte es queda en aquest dispositiu."
          }
        },
        "gl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ao iniciar sesión importáronse os teus complementos e biblioteca á app. A túa conta permanece neste dispositivo."
          }
        },
        "eu": {
          "stringUnit": {
            "state": "translated",
            "value": "Saioa hasteak zure gehigarriak eta liburutegia aplikaziora eramaten ditu. Zure kontua gailu honetan geratzen da."
          }
        },
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Aanmelding haal jou byvoegings en biblioteek in die app in. Jou rekening bly op hierdie toestel."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Daxil olmaq əlavələrinizi və kitabxananızı tətbiqə çəkir. Hesabınız bu cihazda qalır."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Hyrja sjell shtesat dhe bibliotekën tuaj në aplikacion. Llogaria juaj qëndron në këtë pajisje."
          }
        },
        "is": {
          "stringUnit": {
            "state": "translated",
            "value": "Innskráning sækir viðbæturnar þínar og safnið inn í forritið. Reikningurinn þinn er geymdur á þessum tæki."
          }
        },
        "mk": {
          "stringUnit": {
            "state": "translated",
            "value": "Пријавувањето ги внесува вашите додатоци и библиотека во апликацијата. Вашата сметка останува на овој уред."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Kuingia kunachomoa viongezi vyako na maktaba kwenye programu. Akaunti yako inabaki kwenye kifaa hiki."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Кіру қондырмалар мен кітапхананы қосымшаға тартады. Тіркелгіңіз осы құрылғыда сақталады."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Մուտք գործելը ձեր հավելանյութերն ու գրադարանն ծրագիր կբեռնի։ Ձեր հաշիվը կպահվի այս սարքում։"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "translated",
            "value": "შესვლა ნაკადის დამატებებსა და ბიბლიოთეკას აპლიკაციაში ჩაიტვირთება. ანგარიში ინახება ამ მოწყობილობაზე."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਸਾਈਨ ਇਨ ਕਰਨ ਨਾਲ ਤੁਹਾਡੇ ਐਡ-ਆਨ ਅਤੇ ਲਾਇਬ੍ਰੇਰੀ ਐਪ ਵਿੱਚ ਆ ਜਾਂਦੇ ਹਨ। ਤੁਹਾਡਾ ਖਾਤਾ ਇਸ ਡਿਵਾਈਸ 'ਤੇ ਰਹਿੰਦਾ ਹੈ।"
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "साइन इन गर्दा तपाईंका add-on हरू र लाइब्रेरी एपमा आउँछन्। तपाईंको खाता यस उपकरणमा रहन्छ।"
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "መግባት ተጨማሪዎቹ እና ቤተ-መፅሐፍቱ ወደ መተግበሪያው ያምጣሉ። መለያዎ በዚህ መሳሪያ ላይ ይቆያሉ።"
          }
        },
        "km": {
          "stringUnit": {
            "state": "translated",
            "value": "ការចូលទាញ add-ons និងបណ្ណាល័យរបស់អ្នកចូលកម្មវិធី។ គណនីរបស់អ្នករក្សាទុកនៅលើឧបករណ៍នេះ។"
          }
        }
      }
    },
