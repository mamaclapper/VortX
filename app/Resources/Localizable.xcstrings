        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Optional. Ein kostenloses, Ende-zu-Ende-verschlüsseltes Konto hält deine Profile, Einstellungen und Bibliothek geräteübergreifend sicher."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Opcional. Uma conta gratuita e com criptografia de ponta a ponta mantém seus perfis, configurações e biblioteca seguros entre dispositivos."
