        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "任意。無料のエンドツーエンド暗号化アカウントは、プロファイル、設定、ライブラリをデバイス間で安全に保ちます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택 사항. 무료 종단 간 암호화 계정은 기기 간에 프로필, 설정, 라이브러리를 안전하게 보호합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可选。免费的端到端加密账户可在各设备间安全保存你的配置文件、设置和库。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Необязательно. Бесплатный аккаунт со сквозным шифрованием хранит ваши профили, настройки и библиотеку в безопасности на всех устройствах."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वैकल्पिक। एक मुफ़्त, एंड-टू-एंड एन्क्रिप्टेड खाता आपकी प्रोफ़ाइलें, सेटिंग्स और लाइब्रेरी को सभी डिवाइसों में सुरक्षित रखता है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختياري. يحافظ الحساب المجاني المشفّر طرفًا إلى طرف على ملفاتك الشخصية وإعداداتك ومكتبتك آمنة عبر الأجهزة."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İsteğe bağlı. Ücretsiz, uçtan uca şifreli bir hesap, profillerinizi, ayarlarınızı ve kütüphanenizi cihazlar arasında güvende tutar."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Opcional. Uma conta gratuita e encriptada de ponta a ponta mantém os seus perfis, definições e biblioteca seguros entre dispositivos."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Optioneel. Een gratis, eind-tot-eind-versleuteld account houdt je profielen, instellingen en bibliotheek veilig op al je apparaten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Opcjonalne. Bezpłatne, szyfrowane od końca do końca konto chroni Twoje profile, ustawienia i bibliotekę na wszystkich urządzeniach."
