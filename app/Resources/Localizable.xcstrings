        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Jūsų profiliai, nuostatos ir metaduomenų raktai sinchronizuojami su šia paskyra, ištisai užšifruoti. Jie taip pat sinchronizuojami automatiškai akimirką po bet kokio pakeitimo."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Jūsu profili, iestatījumi un metadatu atslēgas sinhronizējas ar šo kontu, pilnībā šifrēti. Tie arī sinhronizējas automātiski mirkli pēc jebkurām izmaiņām."
