        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選用。免費且端對端加密的帳號可讓你的設定檔、設定與資料庫在各裝置間安全無虞。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Opsional. Akun gratis dengan enkripsi ujung-ke-ujung menjaga profil, pengaturan, dan pustaka Anda tetap aman di seluruh perangkat."
