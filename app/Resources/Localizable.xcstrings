    "Install the new build from the GitHub releases page; your sign-in and settings carry over.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Installa la nuova versione dalla pagina delle release di GitHub; il tuo accesso e le impostazioni vengono mantenuti."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Instala la nueva versión desde la página de releases de GitHub; tu inicio de sesión y ajustes se conservan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Installez la nouvelle version depuis la page des releases GitHub ; votre connexion et vos réglages sont conservés."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Installiere den neuen Build von der GitHub-Releases-Seite; deine Anmeldung und Einstellungen werden übernommen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Instale a nova versão pela página de releases do GitHub; seu login e configurações são mantidos."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub のリリースページから新しいビルドをインストールしてください。サインインと設定は引き継がれます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub 릴리스 페이지에서 새 빌드를 설치하세요. 로그인과 설정은 그대로 유지됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从 GitHub 发布页安装新构建版本；你的登录和设置会随之保留。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Установите новую сборку со страницы релизов GitHub; ваш вход и настройки сохранятся."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub रिलीज़ पेज से नया बिल्ड इंस्टॉल करें; आपका साइन-इन और सेटिंग्स साथ चली आती हैं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ثبّت الإصدار الجديد من صفحة الإصدارات على GitHub؛ تنتقل معك بيانات تسجيل دخولك وإعداداتك."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yeni sürümü GitHub sürümler sayfasından yükleyin; oturumunuz ve ayarlarınız aktarılır."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Instale a nova versão a partir da página de lançamentos do GitHub; a sua sessão e definições transitam."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Installeer de nieuwe build vanaf de GitHub-releasepagina; je aanmelding en instellingen blijven behouden."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zainstaluj nową kompilację ze strony wydań GitHub; Twoje logowanie i ustawienia zostaną zachowane."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Installera det nya bygget från GitHub-utgivningssidan; din inloggning och dina inställningar följer med."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請從 GitHub releases 頁面安裝新版本；你的登入與設定都會保留。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Instal build baru dari halaman rilis GitHub; info masuk dan pengaturan Anda ikut terbawa."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ติดตั้งบิลด์ใหม่จากหน้า GitHub releases การลงชื่อเข้าใช้และการตั้งค่าของคุณจะถูกนำมาด้วย"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Cài đặt bản dựng mới từ trang releases trên GitHub; thông tin đăng nhập và cài đặt của bạn sẽ được giữ lại."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Установіть нову збірку зі сторінки релізів GitHub; ваш вхід і налаштування переносяться."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nainstalujte novou verzi ze stránky vydání na GitHubu; vaše přihlášení a nastavení se přenesou."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Εγκαταστήστε τη νέα έκδοση από τη σελίδα εκδόσεων του GitHub· η σύνδεση και οι ρυθμίσεις σας μεταφέρονται."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "התקן את הגרסה החדשה מדף ההפצות ב-GitHub; ההתחברות וההגדרות שלך עוברות יחד."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Installér den nye build fra GitHub-udgivelsessiden; din login og dine indstillinger følger med."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Asenna uusi versio GitHubin julkaisusivulta; kirjautumisesi ja asetuksesi siirtyvät mukana."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Installer den nye versjonen fra utgivelsessiden på GitHub; innloggingen og innstillingene dine følger med."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Instalează noua versiune din pagina de lansări GitHub; autentificarea și setările tale se păstrează."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Telepítsd az új buildet a GitHub kiadások oldaláról; a bejelentkezésed és a beállításaid átkerülnek."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pasang binaan baharu daripada halaman keluaran GitHub; log masuk dan tetapan anda dibawa bersama."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "I-install ang bagong build mula sa pahina ng mga release sa GitHub; sumasama ang iyong sign-in at mga setting."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "نسخه جدید را از صفحه انتشارها در GitHub نصب کنید؛ ورود و تنظیمات شما منتقل می‌شوند."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub রিলিজ পৃষ্ঠা থেকে নতুন বিল্ডটি ইনস্টল করুন; আপনার সাইন-ইন এবং সেটিংস বহাল থাকবে।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub வெளியீடுகள் பக்கத்திலிருந்து புதிய பதிப்பை நிறுவவும்; உங்கள் உள்நுழைவும் அமைப்புகளும் தொடரும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub releases పేజీ నుండి కొత్త బిల్డ్‌ను ఇన్‌స్టాల్ చేయండి; మీ సైన్-ఇన్ మరియు సెట్టింగ్‌లు కొనసాగుతాయి."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub रिलीज पृष्ठावरून नवीन बिल्ड इन्स्टॉल करा; तुमचे साइन-इन आणि सेटिंग्ज तशीच राहतात."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub releases પૃષ્ઠ પરથી નવું બિલ્ડ ઇન્સ્ટોલ કરો; તમારું સાઇન-ઇન અને સેટિંગ સાથે આવી જાય છે."
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub ರಿಲೀಸ್ ಪುಟದಿಂದ ಹೊಸ ಬಿಲ್ಡ್ ಅನ್ನು ಸ್ಥಾಪಿಸಿ; ನಿಮ್ಮ ಸೈನ್-ಇನ್ ಮತ್ತು ಸೆಟ್ಟಿಂಗ್‌ಗಳು ಮುಂದುವರಿಯುತ್ತವೆ."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub റിലീസ് പേജിൽ നിന്ന് പുതിയ ബിൽഡ് ഇൻസ്റ്റാൾ ചെയ്യുക; നിങ്ങളുടെ സൈൻ-ഇന്നും ക്രമീകരണങ്ങളും കൊണ്ടുപോകുന്നു."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub ریلیزز صفحے سے نئی بلڈ انسٹال کریں؛ آپ کا سائن-اِن اور سیٹنگز ساتھ منتقل ہو جاتی ہیں۔"
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Nainštalujte nový build zo stránky vydaní na GitHube; vaše prihlásenie a nastavenia sa prenesú."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Инсталирайте новата компилация от страницата с издания в GitHub; вашето влизане и настройки се пренасят."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Instalirajte novu verziju sa stranice GitHub izdanja; vaša prijava i postavke prenose se."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Инсталирајте нову верзију са странице GitHub издања; ваша пријава и подешавања се преносе."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Namestite novo različico s strani z izdajami na GitHubu; vaša prijava in nastavitve se prenesejo."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Įdiekite naują versiją iš GitHub leidimų puslapio; jūsų prisijungimas ir nuostatos perkeliami automatiškai."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Instalējiet jauno būvējumu no GitHub laidienu lapas; jūsu pierakstīšanās un iestatījumi tiek pārnesti."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Installi uus järk GitHubi väljalasete lehelt; su sisselogimine ja seaded kanduvad üle."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Instal·la la nova versió des de la pàgina de llançaments de GitHub; el teu inici de sessió i la configuració es conserven."
          }
        },
        "gl": {
          "stringUnit": {
            "state": "translated",
            "value": "Instala a nova versión desde a páxina de versións de GitHub; o teu inicio de sesión e os axustes consérvanse."
          }
        },
        "eu": {
          "stringUnit": {
            "state": "translated",
            "value": "Instalatu eraikuntza berria GitHub argitalpen-orritik; zure saioa eta ezarpenak mantentzen dira."
          }
        },
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Installeer die nuwe opbou van die GitHub-vrystellingsblad; jou aanmelding en instellings word oorgedra."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Yeni build-i GitHub relizlər səhifəsindən quraşdırın; girişiniz və parametrləriniz köçürülür."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Instaloni ndërtimin e ri nga faqja e lëshimeve GitHub; hyrja dhe cilësimet tuaja ruhen."
          }
        },
        "is": {
          "stringUnit": {
            "state": "translated",
            "value": "Settu upp nýja smíðina frá GitHub-útgáfusíðunni; innskráning og stillingar flytjast yfir."
          }
        },
        "mk": {
          "stringUnit": {
            "state": "translated",
            "value": "Инсталирајте го новото издание од страницата со изданија на GitHub; вашата најава и поставки се пренесуваат."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Sakinisha toleo jipya kutoka ukurasa wa matoleo ya GitHub; kuingia kwako na mipangilio inabaki."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub шығарылымдар бетінен жаңа жинақты орнатыңыз; кіру деректеріңіз бен параметрлеріңіз сақталады."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Տեղադրեք նոր կառուցումը GitHub-ի թողարկումների էջից. ձեր մուտքն ու կարգավորումները կպահվեն։"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "translated",
            "value": "დააინსტალირეთ ახალი ვერსია GitHub releases გვერდიდან; თქვენი შესვლა და პარამეტრები გადადის."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub ਰਿਲੀਜ਼ ਪੇਜ ਤੋਂ ਨਵਾਂ ਬਿਲਡ ਇੰਸਟਾਲ ਕਰੋ; ਤੁਹਾਡੇ ਸਾਈਨ-ਇਨ ਅਤੇ ਸੈਟਿੰਗਾਂ ਮੌਜੂਦ ਰਹਿੰਦੀਆਂ ਹਨ।"
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub रिलिज पृष्ठबाट नयाँ बिल्ड स्थापना गर्नुहोस्; तपाईंको साइन-इन र सेटिङहरू सुरक्षित रहन्छन्।"
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "አዲሱን ግንባታ ከ GitHub releases ገፅ ይጫኑ፤ ምዝገባዎ እና ቅንብሮቹ ይሸጋገራሉ።"
          }
        },
        "km": {
          "stringUnit": {
            "state": "translated",
            "value": "ដំឡើង build ថ្មីពីទំព័រចេញផ្សាយ GitHub; ការចូល និងការកំណត់របស់អ្នករក្សាទុក។"
          }
        }
      }
    },
    "Keeps its own watch history, synced through your Stremio account to your other devices.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantiene la propria cronologia di visione, sincronizzata tramite il tuo account Stremio sugli altri dispositivi."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantiene su propio historial de visualización, sincronizado a través de tu cuenta Stremio en tus otros dispositivos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Conserve son propre historique de visionnage, synchronisé via votre compte Stremio vers vos autres appareils."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Behält einen eigenen Wiedergabeverlauf, der über dein Stremio-Konto mit deinen anderen Geräten synchronisiert wird."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantém o próprio histórico de exibição, sincronizado pela sua conta Stremio com os seus outros dispositivos."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "独自の視聴履歴を保持し、Stremio アカウントを通じて他のデバイスに同期します。"
