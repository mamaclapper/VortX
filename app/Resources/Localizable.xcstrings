    "Source failed, trying another…  (%@/%@)": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Source failed, trying another…  (%1$@/%2$@)"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sorgente non riuscita, ne provo un'altra…  (%@/%@)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Fuente fallida, probando otra…  (%@/%@)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de la source, tentative d'une autre…  (%@/%@)"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Quelle fehlgeschlagen, eine andere wird versucht …  (%@/%@)"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A fonte falhou, tentando outra…  (%@/%@)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ソースが失敗しました。別のものを試しています…  (%@/%@)"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "소스 실패, 다른 소스 시도 중…  (%@/%@)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "来源失败，正在尝试另一个…  (%@/%@)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Источник не сработал, пробуем другой…  (%@/%@)"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्रोत विफल, कोई अन्य आज़मा रहे हैं…  (%@/%@)"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشل المصدر، جارٍ تجربة آخر…  (%@/%@)"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kaynak başarısız oldu, başka bir tane deneniyor…  (%@/%@)"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A fonte falhou, a tentar outra…  (%@/%@)"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bron mislukt, andere proberen…  (%@/%@)"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Źródło zawiodło, próbuję innego…  (%@/%@)"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Källan misslyckades, provar en annan…  (%@/%@)"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "來源失敗，正在嘗試其他來源…  (%@/%@)"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Sumber gagal, mencoba yang lain…  (%@/%@)"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "แหล่งล้มเหลว กำลังลองอีกแหล่ง…  (%@/%@)"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nguồn thất bại, đang thử nguồn khác…  (%@/%@)"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Джерело не вдалося, пробуємо інше…  (%@/%@)"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zdroj selhal, zkouším jiný…  (%@/%@)"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η πηγή απέτυχε, δοκιμή άλλης…  (%@/%@)"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "המקור נכשל, מנסה אחר…  (%@/%@)"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Kilden mislykkedes, prøver en anden…  (%@/%@)"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lähde epäonnistui, kokeillaan toista…  (%@/%@)"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Kilde feilet, prøver en annen…  (%@/%@)"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Sursa a eșuat, se încearcă alta…  (%@/%@)"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A forrás meghibásodott, másikat próbálok…  (%@/%@)"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Sumber gagal, mencuba yang lain…  (%@/%@)"
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Nabigo ang source, sumusubok ng iba…  (%@/%@)"
          }
        },
        "fa": {
