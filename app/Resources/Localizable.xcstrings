    "%@ can only be edited from that profile": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ può essere modificato solo da quel profilo"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ solo puede editarse desde ese perfil"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ ne peut être modifié que depuis ce profil"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ kann nur über dieses Profil bearbeitet werden"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ só pode ser editado por aquele perfil"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ はそのプロファイルからのみ編集できます"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@은(는) 해당 프로필에서만 편집할 수 있습니다"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 只能从该配置文件中编辑"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ можно редактировать только из этого профиля"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ को केवल उसी प्रोफ़ाइल से संपादित किया जा सकता है"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكن تعديل %@ من ذلك الملف الشخصي فقط"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ yalnızca o profilden düzenlenebilir"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ só pode ser editado a partir desse perfil"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ kan alleen vanuit dat profiel worden bewerkt"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ można edytować tylko z tego profilu"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ kan bara redigeras från den profilen"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 只能從該設定檔編輯"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ hanya dapat diedit dari profil tersebut"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ แก้ไขได้จากโปรไฟล์นั้นเท่านั้น"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ chỉ có thể chỉnh sửa từ hồ sơ đó"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ можна редагувати лише з того профілю"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ lze upravit jen z daného profilu"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το %@ μπορεί να επεξεργαστεί μόνο από εκείνο το προφίλ"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ ניתן לעריכה רק מאותו פרופיל"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ kan kun redigeres fra den profil"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ voidaan muokata vain kyseisestä profiilista"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ kan bare redigeres fra den profilen"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ poate fi editat doar din acel profil"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A(z) %@ csak abból a profilból szerkeszthető"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ hanya boleh disunting daripada profil itu"
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ ay ma-e-edit lamang mula sa profile na iyon"
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ فقط از همان نمایه قابل ویرایش است"
          }
        }
      }
    },
    "%@ other add-on%@ returned no sources for this title.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ other add-on%2$@ returned no sources for this title."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ altro componente aggiuntivo%@ non ha restituito sorgenti per questo titolo."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ otro complemento%@ no devolvió fuentes para este título."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ autre add-on%@ n'a renvoyé aucune source pour ce titre."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ weitere Add-on%@ haben für diesen Titel keine Quellen geliefert."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ outro complemento%@ não retornou fontes para este título."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "他の %@ 個のアドオン%@ は、このタイトルのソースを返しませんでした。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다른 부가 기능 %@개%@에서 이 작품에 대한 소스를 찾지 못했습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 个其他附加组件%@ 未返回此影片的任何来源。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ других дополнени%@ не вернули источников для этого тайтла."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ अन्य ऐड-ऑन%@ ने इस टाइटल के लिए कोई स्रोत नहीं लौटाया।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم تُرجع %@ إضافة أخرى%@ أي مصادر لهذا العنوان."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ diğer eklenti%@ bu içerik için kaynak döndürmedi."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ outro add-on%@ não devolveu fontes para este título."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ andere add-on%@ leverde geen bronnen voor deze titel."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ inny dodatek%@ nie zwrócił źródeł dla tego tytułu."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ andra tillägg%@ returnerade inga källor för den här titeln."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "其他 %@ 個外掛%@均未為此片名傳回任何來源。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ add-on lain%@ tidak mengembalikan sumber untuk judul ini."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "แอดออนอื่นอีก %@ รายการ%@ ไม่พบแหล่งสำหรับเรื่องนี้"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ tiện ích bổ sung khác%@ không trả về nguồn nào cho tựa đề này."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Інші додатки (%@) не повернули джерел для цього тайтлу.%@"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ dalších doplňků%@ nevrátilo pro tento titul žádné zdroje."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ άλλο πρόσθετο%@ δεν επέστρεψε πηγές για αυτόν τον τίτλο."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ הרחבות נוספות%@ לא החזירו מקורות לכותר זה."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ andre tilføjelser%@ returnerede ingen kilder til denne titel."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ muu lisäosa%@ ei palauttanut lähteitä tälle nimikkeelle."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ annet tillegg%@ ga ingen kilder for denne tittelen."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ alt add-on%@ nu a returnat surse pentru acest titlu."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ másik kiegészítő%@ nem talált forrást ehhez a címhez."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ tambahan lain%@ tidak memulangkan sebarang sumber untuk tajuk ini."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ pang add-on%@ ang walang ibinalik na source para sa titulong ito."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ افزونه دیگر%@ هیچ منبعی برای این عنوان برنگرداند."
          }
        }
      }
    },
