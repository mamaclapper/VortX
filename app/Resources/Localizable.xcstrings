    "%@ can only be edited from that profile": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ può essere modificato solo da quel profilo"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ solo puede editarse desde ese perfil"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ ne peut être modifié que depuis ce profil"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ kann nur über dieses Profil bearbeitet werden"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ só pode ser editado por aquele perfil"
          }
