    "Switch to %@ to use it and edit its settings.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Passa a %@ per usarlo e modificarne le impostazioni."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cambia a %@ para usarlo y editar sus ajustes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Basculez vers %@ pour l'utiliser et modifier ses réglages."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wechsle zu %@, um es zu verwenden und seine Einstellungen zu bearbeiten."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mude para %@ para usá-lo e editar suas configurações."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ に切り替えて使用し、その設定を編集します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@(으)로 전환하여 사용하고 설정을 편집하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "切换到 %@ 以使用它并编辑其设置。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Переключитесь на %@, чтобы использовать его и изменить его настройки."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इसका उपयोग करने और इसकी सेटिंग्स संपादित करने के लिए %@ पर स्विच करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بدّل إلى %@ لاستخدامه وتعديل إعداداته."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kullanmak ve ayarlarını düzenlemek için %@ profiline geçin."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Mude para %@ para o usar e editar as suas definições."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Schakel over naar %@ om het te gebruiken en de instellingen ervan te bewerken."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przełącz na %@, aby go używać i edytować jego ustawienia."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Byt till %@ för att använda den och redigera dess inställningar."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "切換至 %@ 以使用它並編輯其設定。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Beralih ke %@ untuk menggunakannya dan mengedit pengaturannya."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "สลับไปที่ %@ เพื่อใช้งานและแก้ไขการตั้งค่า"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chuyển sang %@ để dùng và chỉnh sửa cài đặt của nó."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Перемкніться на %@, щоб використовувати його та редагувати налаштування."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přepněte na %@, abyste jej mohli používat a upravovat jeho nastavení."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Μεταβείτε στο %@ για να το χρησιμοποιήσετε και να επεξεργαστείτε τις ρυθμίσεις του."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "עבור אל %@ כדי להשתמש בו ולערוך את ההגדרות שלו."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Skift til %@ for at bruge den og redigere dens indstillinger."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaihda profiiliin %@ käyttääksesi sitä ja muokataksesi sen asetuksia."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Bytt til %@ for å bruke den og redigere innstillingene dens."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Comută la %@ pentru a-l folosi și a-i edita setările."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Válts a(z) %@ profilra a használatához és a beállításai szerkesztéséhez."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tukar ke %@ untuk menggunakannya dan menyunting tetapannya."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Lumipat sa %@ para gamitin ito at i-edit ang mga setting nito."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "به %@ تغییر دهید تا از آن استفاده کنید و تنظیماتش را ویرایش کنید."
          }
        }
      }
    },
    "That link is not responding right now. Try a different source.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo link non risponde al momento. Prova una sorgente diversa."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ese enlace no responde en este momento. Prueba una fuente diferente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce lien ne répond pas pour le moment. Essayez une autre source."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Link antwortet gerade nicht. Probiere eine andere Quelle."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Esse link não está respondendo agora. Tente outra fonte."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "そのリンクは現在応答していません。別のソースを試してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "해당 링크가 지금 응답하지 않습니다. 다른 소스를 시도해 보세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该链接当前没有响应。请尝试其他来源。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Эта ссылка сейчас не отвечает. Попробуйте другой источник."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वह लिंक अभी प्रतिक्रिया नहीं दे रहा। कोई अलग स्रोत आज़माएँ।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا الرابط لا يستجيب الآن. جرّب مصدرًا مختلفًا."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu bağlantı şu anda yanıt vermiyor. Farklı bir kaynak deneyin."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Essa ligação não está a responder neste momento. Experimente uma fonte diferente."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Die link reageert op dit moment niet. Probeer een andere bron."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ten link w tej chwili nie odpowiada. Wypróbuj inne źródło."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Den länken svarar inte just nu. Prova en annan källa."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "該連結目前沒有回應。請試試其他來源。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tautan tersebut tidak merespons saat ini. Coba sumber lain."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ลิงก์นั้นไม่ตอบสนองในขณะนี้ ลองแหล่งอื่น"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Liên kết đó hiện không phản hồi. Hãy thử một nguồn khác."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Це посилання зараз не відповідає. Спробуйте інше джерело."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tento odkaz právě teď neodpovídá. Zkuste jiný zdroj."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αυτός ο σύνδεσμος δεν ανταποκρίνεται αυτή τη στιγμή. Δοκιμάστε διαφορετική πηγή."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הקישור הזה לא מגיב כרגע. נסה מקור אחר."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Det link svarer ikke lige nu. Prøv en anden kilde."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tuo linkki ei vastaa juuri nyt. Kokeile toista lähdettä."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Den lenken svarer ikke akkurat nå. Prøv en annen kilde."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Acel link nu răspunde momentan. Încearcă o altă sursă."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ez a link jelenleg nem válaszol. Próbálj egy másik forrást."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pautan itu tidak bertindak balas sekarang. Cuba sumber lain."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Hindi tumutugon ang link na iyon ngayon. Subukan ang ibang source."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "آن لینک در حال حاضر پاسخ نمی‌دهد. منبع دیگری را امتحان کنید."
          }
        }
      }
    },
