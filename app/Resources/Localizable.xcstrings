        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Ikiwa kichwa hiki kingepaswa kuwa na vyanzo, kiongezi kinaweza kuwa nje ya mtandao au usanidi wake umekwisha. Jaribu kiongezi kingine cha mtiririko."
