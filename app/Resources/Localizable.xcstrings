        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Imbas dengan telefon anda untuk membuka strim ini di sana  ·  Tekan Kembali untuk menolak"
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "I-scan gamit ang iyong telepono para buksan doon ang stream na ito  ·  Pindutin ang Back para isara"
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "با تلفن خود اسکن کنید تا این جریان آنجا باز شود  ·  برای بستن، Back را فشار دهید"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সেখানে এই স্ট্রিম খুলতে আপনার ফোন দিয়ে স্ক্যান করুন  ·  বাতিল করতে Back চাপুন"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இந்த ஸ்ட்ரீமை அங்கே திறக்க உங்கள் ஃபோனால் ஸ்கேன் செய்யவும்  ·  நீக்க Back-ஐ அழுத்தவும்"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ఈ స్ట్రీమ్‌ను అక్కడ తెరవడానికి మీ ఫోన్‌తో స్కాన్ చేయండి  ·  రద్దు చేయడానికి Back నొక్కండి"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "हा stream तेथे उघडण्यासाठी तुमच्या फोनने स्कॅन करा  ·  डिसमिस करण्यासाठी Back दाबा"
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "આ stream ત્યાં ખોલવા તમારા ફોનથી સ્કેન કરો  ·  બરતરફ કરવા Back દબાવો"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಈ ಸ್ಟ್ರೀಮ್ ಅನ್ನು ಅಲ್ಲಿ ತೆರೆಯಲು ನಿಮ್ಮ ಫೋನ್‌ನಿಂದ ಸ್ಕ್ಯಾನ್ ಮಾಡಿ  ·  ವಜಾಗೊಳಿಸಲು Back ಒತ್ತಿರಿ"
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "ഈ സ്ട്രീം അവിടെ തുറക്കാൻ ഫോൺ ഉപയോഗിച്ച് സ്കാൻ ചെയ്യുക  ·  ഒഴിവാക്കാൻ Back അമർത്തുക"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "وہاں یہ اسٹریم کھولنے کے لیے اپنے فون سے اسکین کریں  ·  مسترد کرنے کے لیے Back دبائیں"
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Naskenujte telefónom, aby ste tam otvorili tento stream  ·  Stlačením Späť zatvoríte"
