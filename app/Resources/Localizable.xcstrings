    },
    "Use the server embedded on this device, or point VortX at a remote / dedicated Stremio server (for example one you run at home).": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa il server integrato in questo dispositivo, oppure punta VortX a un server Stremio remoto / dedicato (ad esempio uno che gestisci a casa)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa el servidor integrado en este dispositivo, o apunta VortX a un servidor Stremio remoto / dedicado (por ejemplo uno que ejecutes en casa)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez le serveur intégré à cet appareil, ou pointez VortX vers un serveur Stremio distant / dédié (par exemple un que vous hébergez chez vous)."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwende den auf diesem Gerät eingebetteten Server oder richte VortX auf einen entfernten / dedizierten Stremio-Server aus (zum Beispiel einen, den du zu Hause betreibst)."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use o servidor integrado neste dispositivo ou aponte a VortX para um servidor Stremio remoto / dedicado (por exemplo, um que você rode em casa)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このデバイスに内蔵されたサーバーを使用するか、VortX をリモート／専用の Stremio サーバー（例えば自宅で運用しているもの）に向けます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 기기에 내장된 서버를 사용하거나, VortX를 원격/전용 Stremio 서버(예: 집에서 직접 운영하는 서버)로 연결하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用本设备上内置的服务器，或让 VortX 指向远程／专用的 Stremio 服务器（例如你在家运行的服务器）。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте сервер, встроенный в это устройство, или укажите VortX удалённый / выделенный сервер Stremio (например, тот, что вы запускаете дома)."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस डिवाइस पर एम्बेडेड सर्वर का उपयोग करें, या VortX को किसी रिमोट / समर्पित Stremio सर्वर की ओर इंगित करें (उदाहरण के लिए जिसे आप घर पर चलाते हों)।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم الخادم المدمج على هذا الجهاز، أو وجّه VortX إلى خادم Stremio بعيد / مخصّص (على سبيل المثال خادم تشغّله في منزلك)."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu cihazda yerleşik sunucuyu kullanın veya VortX'i uzak / özel bir Stremio sunucusuna yönlendirin (örneğin evinizde çalıştırdığınız bir tane)."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Use o servidor incorporado neste dispositivo ou aponte a VortX para um servidor Stremio remoto / dedicado (por exemplo, um que execute em casa)."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gebruik de server die op dit apparaat is ingebouwd, of wijs VortX naar een externe / aparte Stremio-server (bijvoorbeeld een die je thuis draait)."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Użyj serwera wbudowanego na tym urządzeniu lub wskaż VortX zdalny / dedykowany serwer Stremio (na przykład taki, który prowadzisz w domu)."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Använd servern som är inbäddad på den här enheten, eller rikta VortX mot en fjärr-/dedikerad Stremio-server (till exempel en du kör hemma)."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用此裝置上的內嵌伺服器，或讓 VortX 指向遠端／專用的 Stremio 伺服器（例如你在家自架的伺服器）。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Gunakan server yang tertanam di perangkat ini, atau arahkan VortX ke server Stremio jarak jauh / khusus (misalnya yang Anda jalankan di rumah)."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้เซิร์ฟเวอร์ที่ฝังอยู่บนอุปกรณ์นี้ หรือชี้ VortX ไปยังเซิร์ฟเวอร์ Stremio ระยะไกล/เฉพาะ (เช่น เซิร์ฟเวอร์ที่คุณรันที่บ้าน)"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Dùng máy chủ được nhúng trên thiết bị này, hoặc trỏ VortX tới một máy chủ Stremio từ xa / chuyên dụng (ví dụ máy chủ bạn tự chạy ở nhà)."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Використовуйте сервер, вбудований у цей пристрій, або спрямуйте VortX на віддалений / виділений сервер Stremio (наприклад, той, що ви тримаєте вдома)."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Použijte server vestavěný v tomto zařízení, nebo nasměrujte VortX na vzdálený / vyhrazený server Stremio (například ten, který provozujete doma)."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Χρησιμοποιήστε τον διακομιστή που είναι ενσωματωμένος σε αυτή τη συσκευή ή κατευθύνετε το VortX σε έναν απομακρυσμένο / αποκλειστικό διακομιστή Stremio (για παράδειγμα έναν που τρέχετε στο σπίτι)."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "השתמש בשרת המוטמע במכשיר הזה, או הפנה את VortX לשרת Stremio מרוחק / ייעודי (לדוגמה כזה שאתה מפעיל בבית)."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Brug serveren indbygget på denne enhed, eller peg VortX mod en ekstern/dedikeret Stremio-server (for eksempel en, du kører hjemme)."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Käytä tällä laitteella sisäänrakennettua palvelinta tai osoita VortX etä- tai erilliseen Stremio-palvelimeen (esimerkiksi kotonasi pyörivään)."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Bruk serveren som er innebygd på denne enheten, eller pek VortX mot en ekstern / dedikert Stremio-server (for eksempel en du kjører hjemme)."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Folosește serverul încorporat pe acest dispozitiv sau direcționează VortX către un server Stremio la distanță / dedicat (de exemplu unul pe care îl rulezi acasă)."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Használd az ezen az eszközön beépített szervert, vagy irányítsd a VortX-et egy távoli / dedikált Stremio-szerverre (például egy otthon futtatottra)."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Guna pelayan terbenam pada peranti ini, atau arahkan VortX ke pelayan Stremio jauh / khusus (contohnya yang anda jalankan di rumah)."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Gamitin ang server na naka-embed sa device na ito, o ituro ang VortX sa isang remote / dedicated na Stremio server (halimbawa isang pinapatakbo mo sa bahay)."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "از سرور تعبیه‌شده روی این دستگاه استفاده کنید، یا VortX را به یک سرور Stremio راه دور / اختصاصی متصل کنید (برای مثال سروری که در خانه اجرا می‌کنید)."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এই ডিভাইসে অন্তর্নির্মিত সার্ভার ব্যবহার করুন, অথবা VortX-কে একটি দূরবর্তী / নিবেদিত Stremio সার্ভারে নির্দেশ করুন (যেমন আপনি বাড়িতে চালানো একটি)।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இந்தச் சாதனத்தில் உள்ளமைந்த சர்வரைப் பயன்படுத்தவும், அல்லது VortX-ஐ ஒரு தொலைநிலை / பிரத்தியேக Stremio சர்வருக்கு (எடுத்துக்காட்டாக நீங்கள் வீட்டில் இயக்குவது) சுட்டவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ఈ పరికరంలో ఎంబెడ్ చేసిన సర్వర్‌ను వాడండి, లేదా VortXను రిమోట్ / అంకిత Stremio సర్వర్‌కు సూచించండి (ఉదాహరణకు మీరు ఇంట్లో నడిపేది)."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "या डिव्हाइसवर अंगभूत असलेला सर्व्हर वापरा, किंवा VortX ला रिमोट / समर्पित Stremio सर्व्हरकडे निर्देशित करा (उदाहरणार्थ तुम्ही घरी चालवता तो)."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "આ ઉપકરણ પર એમ્બેડેડ સર્વર વાપરો, અથવા VortX ને દૂરના / સમર્પિત Stremio સર્વર પર નિર્દેશ કરો (ઉદાહરણ તરીકે તમે ઘરે ચલાવો છો તે)."
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಈ ಸಾಧನದಲ್ಲಿ ಅಂತರ್ನಿರ್ಮಿತ ಸರ್ವರ್ ಅನ್ನು ಬಳಸಿ, ಅಥವಾ VortX ಅನ್ನು ದೂರಸ್ಥ / ಮೀಸಲಾದ Stremio ಸರ್ವರ್‌ಗೆ ಸೂಚಿಸಿ (ಉದಾಹರಣೆಗೆ ನೀವು ಮನೆಯಲ್ಲಿ ಚಲಾಯಿಸುವಂತಹದ್ದು)."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "ഈ ഉപകരണത്തിൽ എംബഡ് ചെയ്ത സെർവർ ഉപയോഗിക്കുക, അല്ലെങ്കിൽ ഒരു റിമോട്ട് / സമർപ്പിത Stremio സെർവറിലേക്ക് VortX-നെ ചൂണ്ടിക്കാട്ടുക (ഉദാഹരണത്തിന് നിങ്ങൾ വീട്ടിൽ പ്രവർത്തിപ്പിക്കുന്ന ഒന്ന്)."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اس ڈیوائس پر ایمبیڈڈ سرور استعمال کریں، یا VortX کو کسی ریموٹ / مخصوص Stremio سرور کی طرف منتقل کریں (مثلاً وہ جو آپ گھر پر چلاتے ہیں)۔"
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Použite server zabudovaný v tomto zariadení, alebo nasmerujte VortX na vzdialený / dedikovaný server Stremio (napríklad taký, ktorý prevádzkujete doma)."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Използвайте сървъра, вграден на това устройство, или насочете VortX към отдалечен / специализиран Stremio сървър (например такъв, който поддържате вкъщи)."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Koristite poslužitelj ugrađen na ovom uređaju ili usmjerite VortX na udaljeni / namjenski Stremio poslužitelj (na primjer onaj koji pokrećete kod kuće)."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Користите сервер уграђен на овом уређају, или усмерите VortX на удаљени / наменски Stremio сервер (на пример онај који имате код куће)."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uporabite strežnik, vgrajen v tej napravi, ali usmerite VortX na oddaljeni/namenski strežnik Stremio (na primer tistega, ki ga poganjate doma)."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Naudokite serverį, įtaisytą šiame įrenginyje, arba nukreipkite VortX į nuotolinį / dedikuotą Stremio serverį (pavyzdžiui, tą, kurį turite namuose)."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Izmantojiet šajā ierīcē iegulto serveri vai norādiet VortX uz attālu / dedicētu Stremio serveri (piemēram, tādu, kuru darbināt mājās)."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Kasuta selles seadmes sisseehitatud serverit või suuna VortX kaug- / sihtotstarbelisele Stremio serverile (näiteks sellisele, mida pead kodus)."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilitza el servidor integrat en aquest dispositiu, o apunta VortX a un servidor de Stremio remot o dedicat (per exemple, un que tinguis a casa)."
          }
        },
        "gl": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa o servidor integrado neste dispositivo ou apunta VortX a un servidor Stremio remoto/dedicado (por exemplo, un que teñas na casa)."
          }
        },
        "eu": {
          "stringUnit": {
            "state": "translated",
            "value": "Erabili gailu honetan integratutako zerbitzaria, edo zuzendu VortX urruneko / dedikaturiko Stremio zerbitzari batera (adibidez, etxean exekutatzen duzun bat)."
          }
        },
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Gebruik die bediener wat op hierdie toestel ingebed is, of wys VortX na 'n afgeleë/toegewyde Stremio-bediener (byvoorbeeld een wat jy tuis bedryf)."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu cihazda yerləşdirilmiş serverdən istifadə edin və ya VortX-i uzaqdan/xüsusi Stremio serverinə yönəldin (məsələn evdə işlətdiyiniz biri)."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Përdorni serverin e integruar në këtë pajisje, ose drejtoni VortX drejt një serveri të largët/të dedikuar Stremio (për shembull njerit që e drejtoni në shtëpi)."
          }
        },
        "is": {
          "stringUnit": {
            "state": "translated",
            "value": "Notaðu þjóninn sem er innbyggður á þessu tæki, eða beindu VortX að fjarlægu / sérsniðnu Stremio-þjóni (til dæmis einum sem þú keyrir heima hjá þér)."
          }
        },
        "mk": {
          "stringUnit": {
            "state": "translated",
            "value": "Користете го серверот вграден на овој уред или насочете го VortX кон оддалечен / наменски Stremio сервер (на пример еден кој го стартувате дома)."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Tumia seva iliyojumuishwa kwenye kifaa hiki, au elekeza VortX kwenye seva ya mbali/iliyowekwa (kwa mfano moja unayoendesha nyumbani)."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Осы құрылғыдағы кірістірілген серверді пайдаланыңыз немесе VortX-ті қашықтағы/арнайы Stremio серверіне бағыттаңыз (мысалы, үйіңізде іске қосқан сервер)."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Օգտագործեք այս սարքում ներկառուցված սերվերը, կամ VortX-ն ուղղեք հեռավոր/նվիրված Stremio սերվերի (օրինակ՝ տանն աշխատող)։"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "translated",
            "value": "გამოიყენეთ ამ მოწყობილობაზე ჩაშენებული სერვერი, ან მიუთითეთ VortX-ს დისტანციური/გამოყოფილი Stremio სერვერი (მაგ., სახლში გაშვებული)."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਇਸ ਡਿਵਾਈਸ 'ਤੇ ਐਂਬੈੱਡ ਕੀਤਾ ਸਰਵਰ ਵਰਤੋ, ਜਾਂ VortX ਨੂੰ ਕਿਸੇ ਰਿਮੋਟ/ਸਮਰਪਿਤ Stremio ਸਰਵਰ ਵੱਲ ਦੱਸੋ (ਉਦਾਹਰਨ ਲਈ ਜੋ ਤੁਸੀਂ ਘਰ ਵਿੱਚ ਚਲਾਉਂਦੇ ਹੋ)।"
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "यस उपकरणमा एम्बेडेड सर्भर प्रयोग गर्नुहोस्, वा VortX लाई रिमोट/समर्पित Stremio सर्भरतिर निर्देशित गर्नुहोस् (उदाहरणका लागि, तपाईंले घरमा चलाउनुभएको)।"
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "በዚህ መሳሪያ ላይ የተቀናጀ አገልጋዩን ተጠቀሙ፣ ወይም VortX ወደ ሩቅ/ቀጥ ያለ Stremio አገልጋይ ጠቁሙ (ለምሳሌ ቤት ላይ የሚሮጡ)።"
          }
        },
        "km": {
          "stringUnit": {
            "state": "translated",
            "value": "ប្រើ server ដែលបង្កប់នៅឧបករណ៍នេះ ឬចង្អុល VortX ទៅ Stremio server ពីចម្ងាយ/ឯករាជ្យ (ឧ. ដែលអ្នករត់នៅផ្ទះ)។"
          }
        }
      }
    },
