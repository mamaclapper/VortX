            "value": "इस स्ट्रीम को वहाँ खोलने के लिए अपने फ़ोन से स्कैन करें  ·  खारिज करने के लिए Back दबाएँ"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "امسح بهاتفك لفتح هذا المصدر هناك  ·  اضغط رجوع للإغلاق"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Akışı orada açmak için telefonunuzla tarayın  ·  Kapatmak için Geri'ye basın"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Leia com o telemóvel para abrir esta stream aí  ·  Prima Voltar para fechar"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Scan met je telefoon om deze stream daar te openen  ·  Druk op Terug om te sluiten"
