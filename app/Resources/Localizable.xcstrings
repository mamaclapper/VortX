        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ایڈ-آن مینی فیسٹ URLs چسپاں کریں، ہر سطر پر ایک، پھر انہیں سب کو ایک ہی مرحلے میں انسٹال کریں۔"
