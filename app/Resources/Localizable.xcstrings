    "Styles the built-in player's subtitles. Pick which subtitle track to show from the player while watching.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Definisce lo stile dei sottotitoli del lettore integrato. Scegli quale traccia di sottotitoli mostrare dal lettore durante la visione."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Da estilo a los subtítulos del reproductor integrado. Elige qué pista de subtítulos mostrar desde el reproductor mientras ves algo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Met en forme les sous-titres du lecteur intégré. Choisissez la piste de sous-titres à afficher depuis le lecteur pendant le visionnage."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gestaltet die Untertitel des integrierten Players. Wähle während des Schauens im Player, welche Untertitelspur angezeigt wird."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Estiliza as legendas do player integrado. Escolha qual faixa de legenda exibir a partir do player enquanto assiste."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "内蔵プレーヤーの字幕のスタイルを設定します。視聴中にプレーヤーから表示する字幕トラックを選択できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "내장 플레이어의 자막 스타일을 지정합니다. 시청 중 플레이어에서 표시할 자막 트랙을 선택하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为内置播放器的字幕设置样式。在观看时从播放器中选择要显示的字幕轨道。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Оформляет субтитры встроенного плеера. Выберите в плеере, какую дорожку субтитров показывать во время просмотра."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बिल्ट-इन प्लेयर के सबटाइटल को स्टाइल करता है। देखते समय प्लेयर से चुनें कि कौन सा सबटाइटल ट्रैक दिखाना है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يصمّم ترجمات المشغّل المدمج. اختر مسار الترجمة الذي تريد عرضه من المشغّل أثناء المشاهدة."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yerleşik oynatıcının altyazılarını biçimlendirir. İzlerken oynatıcıdan hangi altyazı parçasının gösterileceğini seçin."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Define o estilo das legendas do leitor incorporado. Escolha qual a faixa de legendas a mostrar a partir do leitor durante a visualização."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bepaalt de stijl van de ondertiteling in de ingebouwde speler. Kies tijdens het kijken vanuit de speler welk ondertitelspoor wordt getoond."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nadaje styl napisom wbudowanego odtwarzacza. Wybierz w odtwarzaczu, którą ścieżkę napisów wyświetlać podczas oglądania."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Formaterar undertexterna i den inbyggda spelaren. Välj vilket undertextspår som ska visas från spelaren medan du tittar."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "設定內建播放器字幕的樣式。觀看時可從播放器選擇要顯示哪一條字幕軌。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Menata subtitle pemutar bawaan. Pilih trek subtitle mana yang akan ditampilkan dari pemutar saat menonton."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "จัดสไตล์คำบรรยายของตัวเล่นในตัว เลือกแทร็กคำบรรยายที่จะแสดงจากตัวเล่นขณะรับชม"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tạo kiểu cho phụ đề của trình phát tích hợp. Chọn rãnh phụ đề muốn hiển thị từ trình phát khi đang xem."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Стилізує субтитри вбудованого плеєра. Виберіть, яку доріжку субтитрів показувати, прямо з плеєра під час перегляду."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Stylizuje titulky vestavěného přehrávače. Vyberte v přehrávači během sledování, kterou stopu titulků zobrazit."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Διαμορφώνει τους υπότιτλους της ενσωματωμένης αναπαραγωγής. Επιλέξτε ποιο κομμάτι υπότιτλων θα εμφανίζεται από την αναπαραγωγή κατά την παρακολούθηση."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "מעצב את הכתוביות של הנגן המובנה. בחר איזה ערוץ כתוביות להציג מתוך הנגן בזמן הצפייה."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Styler underteksterne i den indbyggede afspiller. Vælg hvilket undertekstspor der skal vises fra afspilleren, mens du ser."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tyylittelee sisäänrakennetun soittimen tekstitykset. Valitse soittimesta, mikä tekstitysraita näytetään katselun aikana."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Stiler undertekstene i den innebygde spilleren. Velg hvilket undertekstspor som skal vises fra spilleren mens du ser."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Stilizează subtitrările playerului încorporat. Alege ce pistă de subtitrare să fie afișată din player în timpul vizionării."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A beépített lejátszó feliratait stílusozza. Nézés közben a lejátszóból választhatod ki, melyik feliratsávot jelenítse meg."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Menggayakan sari kata pemain terbina dalam. Pilih trek sari kata mana untuk dipaparkan daripada pemain semasa menonton."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini-istilo ang mga subtitle ng built-in na player. Piliin kung aling subtitle track ang ipapakita mula sa player habang nanonood."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "زیرنویس‌های پخش‌کننده داخلی را استایل‌دهی می‌کند. در حین تماشا از داخل پخش‌کننده انتخاب کنید کدام مسیر زیرنویس نمایش داده شود."
          }
        }
      }
    },
