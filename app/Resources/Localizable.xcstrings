        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "자체 시청 기록을 유지하며, Stremio 계정을 통해 다른 기기와 동기화됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保留它自己的观看历史，通过你的 Stremio 账户同步到你的其他设备。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ведёт собственную историю просмотра, синхронизируемую через ваш аккаунт Stremio с другими устройствами."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपना खुद का देखने का इतिहास रखता है, जो आपके Stremio खाते के ज़रिए आपके अन्य डिवाइसों में सिंक होता है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحتفظ بسجل مشاهدته الخاص، مُزامَنًا عبر حساب Stremio الخاص بك إلى أجهزتك الأخرى."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Stremio hesabınız aracılığıyla diğer cihazlarınıza eşitlenen, kendi izleme geçmişini tutar."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantém o seu próprio histórico de visualização, sincronizado através da sua conta Stremio com os seus outros dispositivos."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Houdt zijn eigen kijkgeschiedenis bij, gesynchroniseerd via je Stremio-account naar je andere apparaten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zachowuje własną historię oglądania, synchronizowaną przez Twoje konto Stremio z innymi urządzeniami."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Behåller sin egen tittarhistorik, synkad via ditt Stremio-konto till dina andra enheter."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "保有自己的觀看記錄，並透過你的 Stremio 帳號同步至你的其他裝置。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Menyimpan riwayat tontonnya sendiri, disinkronkan melalui akun Stremio Anda ke perangkat lain."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เก็บประวัติการดูของตัวเอง ซิงค์ผ่านบัญชี Stremio ของคุณไปยังอุปกรณ์อื่น"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Giữ lịch sử xem riêng, được đồng bộ qua tài khoản Stremio của bạn tới các thiết bị khác."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Веде власну історію перегляду, синхронізовану через ваш акаунт Stremio з іншими пристроями."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Uchovává si vlastní historii sledování, synchronizovanou přes váš účet Stremio do ostatních zařízení."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Διατηρεί το δικό του ιστορικό παρακολούθησης, συγχρονισμένο μέσω του λογαριασμού Stremio σας με τις άλλες συσκευές σας."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "שומרת היסטוריית צפייה משלה, מסונכרנת דרך חשבון Stremio שלך למכשירים האחרים שלך."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Beholder sin egen seehistorik, synkroniseret via din Stremio-konto til dine andre enheder."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Säilyttää oman katseluhistoriansa, joka synkronoidaan Stremio-tilisi kautta muihin laitteisiisi."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Beholder sin egen avspillingshistorikk, synkronisert gjennom Stremio-kontoen din til de andre enhetene dine."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Își păstrează propriul istoric de vizionare, sincronizat prin contul tău Stremio cu celelalte dispozitive."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Saját megtekintési előzményeket vezet, amelyek a Stremio-fiókodon keresztül szinkronizálódnak a többi eszközödre."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Mengekalkan sejarah tontonannya sendiri, disegerakkan melalui akaun Stremio anda ke peranti lain anda."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Pinapanatili ang sarili nitong watch history, naka-sync sa pamamagitan ng iyong Stremio account sa iyong ibang mga device."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "تاریخچه تماشای خودش را نگه می‌دارد که از طریق حساب Stremio شما با دستگاه‌های دیگرتان همگام می‌شود."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "নিজের দেখার ইতিহাস রাখে, যা আপনার Stremio অ্যাকাউন্টের মাধ্যমে আপনার অন্যান্য ডিভাইসে সিঙ্ক হয়।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "தனது சொந்த பார்வை வரலாற்றை வைத்திருக்கிறது, உங்கள் Stremio கணக்கின் வழியாக உங்கள் பிற சாதனங்களுடன் ஒத்திசைக்கப்படுகிறது."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "దీని స్వంత చూసిన చరిత్రను ఉంచుకుంటుంది, మీ Stremio ఖాతా ద్వారా మీ ఇతర పరికరాలకు సింక్ చేయబడుతుంది."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "स्वतःचा पाहण्याचा इतिहास ठेवते, जो तुमच्या Stremio खात्याद्वारे तुमच्या इतर डिव्हाइसशी सिंक होतो."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "તેનો પોતાનો જોવાનો ઇતિહાસ રાખે છે, જે તમારા Stremio account દ્વારા તમારા અન્ય ઉપકરણો સાથે સિંક થાય છે."
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ತನ್ನದೇ ಆದ ವೀಕ್ಷಣಾ ಇತಿಹಾಸವನ್ನು ಇರಿಸಿಕೊಳ್ಳುತ್ತದೆ, ನಿಮ್ಮ Stremio ಖಾತೆಯ ಮೂಲಕ ನಿಮ್ಮ ಇತರ ಸಾಧನಗಳಿಗೆ ಸಿಂಕ್ ಆಗುತ್ತದೆ."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "സ്വന്തം കാഴ്ച ചരിത്രം നിലനിർത്തുന്നു, നിങ്ങളുടെ Stremio അക്കൗണ്ടിലൂടെ നിങ്ങളുടെ മറ്റ് ഉപകരണങ്ങളിലേക്ക് സിങ്ക് ചെയ്യപ്പെടുന്നു."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اپنی الگ دیکھنے کی تاریخ رکھتا ہے، جو آپ کے Stremio اکاؤنٹ کے ذریعے آپ کی دیگر ڈیوائسز پر سنک ہوتی ہے۔"
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Uchováva si vlastnú históriu sledovania, synchronizovanú cez váš účet Stremio do vašich ostatných zariadení."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Поддържа собствена история на гледане, синхронизирана чрез вашия Stremio акаунт към другите ви устройства."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Zadržava vlastitu povijest gledanja, sinkroniziranu putem vašeg Stremio računa na druge uređaje."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Чува сопствену историју гледања, синхронизовану кроз ваш Stremio налог са осталим уређајима."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ima svojo zgodovino gledanja, sinhronizirano prek vašega računa Stremio z drugimi napravami."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Saugo savo paties žiūrėjimo istoriją, sinchronizuojamą per jūsų Stremio paskyrą su kitais įrenginiais."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Uztur savu skatīšanās vēsturi, kas sinhronizēta caur jūsu Stremio kontu ar jūsu citām ierīcēm."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoiab oma vaatamisajalugu, mis sünkroonitakse su Stremio konto kaudu su teistesse seadmetesse."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Manté el seu propi historial de visualització, sincronitzat a través del teu compte de Stremio als altres dispositius."
          }
        },
        "gl": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén o seu propio historial de visualización, sincronizado coa túa conta de Stremio nos teus outros dispositivos."
          }
        },
        "eu": {
          "stringUnit": {
            "state": "translated",
            "value": "Bere ikusteko historia propioa mantentzen du, Stremio kontuaren bidez beste gailuekin sinkronizatuta."
          }
        },
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Hou sy eie kykvorderingby, gesinkroniseer deur jou Stremio-rekening na jou ander toestelle."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Öz izlənmə tarixçəsini saxlayır, Stremio hesabınız vasitəsilə digər cihazlarınızla sinxronlaşır."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Mban historinë e vet të shikimit, sinkronizuar nëpërmjet llogarisë tuaj Stremio me pajisjet e tjera."
          }
        },
        "is": {
          "stringUnit": {
            "state": "translated",
            "value": "Heldur eigin horfuferli, samstillt í gegnum Stremio-reikninginn þinn við önnur tæki þín."
          }
        },
        "mk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ја чува сопствената историја на гледање, синхронизирана преку вашата Stremio сметка на другите ваши уреди."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Inaweka historia yake ya kutazama, iliyosawazishwa kupitia akaunti yako ya Stremio kwenye vifaa vyako vingine."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Stremio тіркелгіңіз арқылы басқа құрылғылармен синхрондалған, жеке қараушы тарихын сақтайды."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Պահպանում է իր սեփական դիտման պատմությունը, համաժամեցված ձեր Stremio հաշվի միջոցով ձեր մյուս սարքերում։"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "translated",
            "value": "ინახავს საკუთარ ყურების ისტორიას, სინქრონიზებულს Stremio ანგარიშის მეშვეობით სხვა მოწყობილობებთან."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਆਪਣਾ ਵੇਖਣ ਦਾ ਇਤਿਹਾਸ ਰੱਖਦਾ ਹੈ, ਤੁਹਾਡੇ Stremio ਖਾਤੇ ਰਾਹੀਂ ਦੂਜੇ ਡਿਵਾਈਸਾਂ ਨਾਲ ਸਿੰਕ ਹੁੰਦਾ ਹੈ।"
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "आफ्नो Stremio खातामार्फत अन्य उपकरणहरूमा सिङ्क गर्दै आफ्नै हेर्ने इतिहास राख्छ।"
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "የዝርዝር የሰዓት ታሪኩን ከሌሎቹ መሳሪያዎቹ ጋር በ Stremio መለያዎ ያምሳምሳሉ።"
          }
        },
        "km": {
          "stringUnit": {
            "state": "translated",
            "value": "រក្សាប្រវត្តិមើលផ្ទាល់ខ្លួន ធ្វើសមកាលកម្មតាមរយៈគណនី Stremio របស់អ្នកទៅឧបករណ៍ផ្សេងទៀតរបស់អ្នក។"
          }
