    "Sideload the new IPA from the GitHub releases page, your sign-in and settings carry over.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Installa tramite sideload il nuovo IPA dalla pagina delle release di GitHub; il tuo accesso e le impostazioni vengono mantenuti."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Instala mediante sideload el nuevo IPA desde la página de releases de GitHub; tu inicio de sesión y ajustes se conservan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chargez le nouveau IPA en sideload depuis la page des releases GitHub, votre connexion et vos réglages sont conservés."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lade die neue IPA von der GitHub-Releases-Seite per Sideload; deine Anmeldung und Einstellungen werden übernommen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Faça o sideload do novo IPA pela página de releases do GitHub; seu login e configurações são mantidos."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub のリリースページから新しい IPA をサイドロードしてください。サインインと設定は引き継がれます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub 릴리스 페이지에서 새 IPA를 사이드로드하세요. 로그인과 설정은 그대로 유지됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从 GitHub 发布页旁加载新的 IPA，你的登录和设置会随之保留。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Загрузите новый IPA со страницы релизов GitHub, ваш вход и настройки сохранятся."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub रिलीज़ पेज से नया IPA साइडलोड करें, आपका साइन-इन और सेटिंग्स साथ चली आती हैं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حمّل ملف IPA الجديد جانبيًا من صفحة الإصدارات على GitHub، تنتقل معك بيانات تسجيل دخولك وإعداداتك."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yeni IPA'yı GitHub sürümler sayfasından yandan yükleyin, oturumunuz ve ayarlarınız aktarılır."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Faça sideload do novo IPA a partir da página de lançamentos do GitHub; a sua sessão e definições transitam."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sideload de nieuwe IPA vanaf de GitHub-releasepagina, je aanmelding en instellingen blijven behouden."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Załaduj nowy plik IPA ze strony wydań GitHub; Twoje logowanie i ustawienia zostaną zachowane."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Sidladda den nya IPA:n från GitHub-utgivningssidan, din inloggning och dina inställningar följer med."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請從 GitHub releases 頁面側載新的 IPA，你的登入與設定都會保留。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Sideload IPA baru dari halaman rilis GitHub, info masuk dan pengaturan Anda ikut terbawa."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ไซด์โหลด IPA ใหม่จากหน้า GitHub releases การลงชื่อเข้าใช้และการตั้งค่าของคุณจะถูกนำมาด้วย"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Sideload bản IPA mới từ trang releases trên GitHub, thông tin đăng nhập và cài đặt của bạn sẽ được giữ lại."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Завантажте новий IPA зі сторінки релізів GitHub методом sideload, ваш вхід і налаштування переносяться."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Načtěte (sideload) novou IPA ze stránky vydání na GitHubu, vaše přihlášení a nastavení se přenesou."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Φορτώστε με sideload το νέο IPA από τη σελίδα εκδόσεων του GitHub· η σύνδεση και οι ρυθμίσεις σας μεταφέρονται."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "טען בצד את ה-IPA החדש מדף ההפצות ב-GitHub, ההתחברות וההגדרות שלך עוברות יחד."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Sideload den nye IPA fra GitHub-udgivelsessiden, din login og dine indstillinger følger med."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Sivulataa uusi IPA GitHubin julkaisusivulta, kirjautumisesi ja asetuksesi siirtyvät mukana."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Sidelast den nye IPA-en fra utgivelsessiden på GitHub, innloggingen og innstillingene dine følger med."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Încarcă manual noul IPA din pagina de lansări GitHub, autentificarea și setările tale se păstrează."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Telepítsd oldalról (sideload) az új IPA-t a GitHub kiadások oldaláról, a bejelentkezésed és a beállításaid átkerülnek."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Muat sisi IPA baharu daripada halaman keluaran GitHub, log masuk dan tetapan anda dibawa bersama."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "I-sideload ang bagong IPA mula sa pahina ng mga release sa GitHub, sumasama ang iyong sign-in at mga setting."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "نسخه جدید IPA را از صفحه انتشارها در GitHub بارگذاری جانبی کنید، ورود و تنظیمات شما منتقل می‌شوند."
          }
        }
      }
    },
    "Signing in pulls your add-ons and library into the app. Your account stays on this device.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Accedendo, i tuoi componenti aggiuntivi e la libreria vengono caricati nell'app. Il tuo account resta su questo dispositivo."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Al iniciar sesión, tus complementos y tu biblioteca se cargan en la app. Tu cuenta permanece en este dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La connexion importe vos add-ons et votre bibliothèque dans l'app. Votre compte reste sur cet appareil."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Durch die Anmeldung werden deine Add-ons und deine Bibliothek in die App geladen. Dein Konto bleibt auf diesem Gerät."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Fazer login traz seus complementos e biblioteca para o app. Sua conta permanece neste dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サインインすると、アドオンとライブラリがアプリに取り込まれます。アカウントはこのデバイスに保持されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로그인하면 부가 기능과 라이브러리가 앱으로 가져와집니다. 계정은 이 기기에 보관됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "登录会将你的附加组件和库拉取到应用中。你的账户保留在本设备上。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вход подтягивает ваши дополнения и библиотеку в приложение. Ваш аккаунт остаётся на этом устройстве."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "साइन इन करने से आपके ऐड-ऑन और लाइब्रेरी ऐप में आ जाते हैं। आपका खाता इसी डिवाइस पर रहता है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يسحب تسجيل الدخول إضافاتك ومكتبتك إلى التطبيق. يبقى حسابك على هذا الجهاز."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Oturum açmak, eklentilerinizi ve kütüphanenizi uygulamaya çeker. Hesabınız bu cihazda kalır."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Iniciar sessão traz os seus add-ons e biblioteca para a app. A sua conta fica neste dispositivo."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aanmelden haalt je add-ons en bibliotheek in de app. Je account blijft op dit apparaat."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zalogowanie się pobiera Twoje dodatki i bibliotekę do aplikacji. Twoje konto pozostaje na tym urządzeniu."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Inloggning hämtar dina tillägg och ditt bibliotek till appen. Ditt konto stannar på den här enheten."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "登入會將你的外掛與資料庫拉進 App。你的帳號會留在此裝置上。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Masuk menarik add-on dan pustaka Anda ke dalam aplikasi. Akun Anda tetap di perangkat ini."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การลงชื่อเข้าใช้จะดึงแอดออนและไลบรารีของคุณเข้าสู่แอป บัญชีของคุณจะอยู่บนอุปกรณ์นี้"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Việc đăng nhập kéo các tiện ích bổ sung và thư viện của bạn vào ứng dụng. Tài khoản của bạn vẫn ở trên thiết bị này."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Вхід підтягує ваші додатки та бібліотеку в застосунок. Ваш акаунт лишається на цьому пристрої."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přihlášení načte vaše doplňky a knihovnu do aplikace. Váš účet zůstává v tomto zařízení."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η σύνδεση φέρνει τα πρόσθετα και τη βιβλιοθήκη σας στην εφαρμογή. Ο λογαριασμός σας παραμένει σε αυτή τη συσκευή."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "התחברות מושכת את ההרחבות והספרייה שלך לאפליקציה. החשבון שלך נשאר במכשיר הזה."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Når du logger ind, hentes dine tilføjelser og dit bibliotek ind i appen. Din konto bliver på denne enhed."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kirjautuminen tuo lisäosasi ja kirjastosi sovellukseen. Tilisi pysyy tällä laitteella."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Innlogging henter tilleggene og biblioteket ditt inn i appen. Kontoen din blir på denne enheten."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Autentificarea aduce add-on-urile și biblioteca în aplicație. Contul tău rămâne pe acest dispozitiv."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A bejelentkezés behúzza a kiegészítőidet és a könyvtáradat az appba. A fiókod ezen az eszközön marad."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Log masuk menarik tambahan dan pustaka anda ke dalam aplikasi. Akaun anda kekal pada peranti ini."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Ang pag-sign in ay nagdadala ng iyong mga add-on at library sa app. Nananatili sa device na ito ang iyong account."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "ورود به حساب، افزونه‌ها و کتابخانه شما را به برنامه می‌آورد. حساب شما روی این دستگاه می‌ماند."
          }
        }
      }
    },
