    },
    "The app quits immediately. Open it again from the Home Screen; the streaming server restarts with it.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'app si chiude immediatamente. Riaprila dalla schermata Home; il server di streaming si riavvia con essa."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La app se cierra de inmediato. Vuelve a abrirla desde la pantalla de inicio; el servidor de streaming se reinicia con ella."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'app se ferme immédiatement. Rouvrez-la depuis l'écran d'accueil ; le serveur de streaming redémarre avec elle."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die App wird sofort beendet. Öffne sie erneut über den Home-Bildschirm; der Streaming-Server startet mit ihr neu."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O app fecha imediatamente. Abra-o novamente pela Tela de Início; o servidor de streaming reinicia junto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリはすぐに終了します。ホーム画面から再度開いてください。ストリーミングサーバーも一緒に再起動します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "앱이 즉시 종료됩니다. 홈 화면에서 다시 여세요. 스트리밍 서버도 함께 다시 시작됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应用会立即退出。请从主屏幕再次打开它；流媒体服务器会随之重启。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Приложение немедленно закрывается. Откройте его снова с главного экрана; сервер потоковой передачи запустится вместе с ним."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ऐप तुरंत बंद हो जाता है। उसे Home Screen से फिर से खोलें; स्ट्रीमिंग सर्वर उसके साथ पुनः आरंभ होता है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يُغلَق التطبيق فورًا. افتحه مجددًا من الشاشة الرئيسية؛ يُعاد تشغيل خادم البث معه."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Uygulama hemen kapanır. Ana Ekran'dan tekrar açın; akış sunucusu onunla birlikte yeniden başlar."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A app encerra de imediato. Abra-a novamente a partir do ecrã principal; o servidor de streaming reinicia com ela."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De app sluit meteen af. Open hem opnieuw vanaf het beginscherm; de streamingserver start mee opnieuw op."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplikacja natychmiast się zamknie. Otwórz ją ponownie z ekranu głównego; serwer strumieniowania uruchomi się razem z nią."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Appen avslutas omedelbart. Öppna den igen från hemskärmen; strömningsservern startas om med den."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "App 會立即結束。請從主畫面再次開啟它；串流伺服器會隨之重新啟動。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplikasi langsung keluar. Buka lagi dari Layar Beranda; server streaming dimulai ulang bersamanya."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "แอปจะปิดทันที เปิดใหม่จากหน้าจอโฮม เซิร์ฟเวอร์สตรีมมิงจะรีสตาร์ทไปพร้อมกัน"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ứng dụng sẽ thoát ngay lập tức. Hãy mở lại từ Màn hình chính; máy chủ phát sẽ khởi động lại cùng với nó."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Застосунок негайно закривається. Відкрийте його знову з Домашнього екрана; сервер потокового відтворення перезапуститься разом із ним."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplikace se okamžitě ukončí. Otevřete ji znovu z Domovské obrazovky; streamovací server se s ní spustí znovu."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η εφαρμογή κλείνει αμέσως. Ανοίξτε την ξανά από την Αρχική οθόνη· ο διακομιστής ροής επανεκκινείται μαζί της."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "האפליקציה נסגרת מיד. פתח אותה שוב ממסך הבית; שרת ההזרמה מופעל מחדש יחד איתה."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Appen lukker med det samme. Åbn den igen fra hjemmeskærmen; streaming-serveren genstarter sammen med den."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Sovellus sulkeutuu välittömästi. Avaa se uudelleen Koti-näytöltä; suoratoistopalvelin käynnistyy sen mukana."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Appen avsluttes umiddelbart. Åpne den igjen fra Hjem-skjermen; strømmeserveren starter på nytt sammen med den."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplicația se închide imediat. Deschide-o din nou din ecranul principal; serverul de streaming repornește odată cu ea."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az app azonnal kilép. Nyisd meg újra a Kezdőképernyőről; a streaming szerver vele együtt újraindul."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplikasi keluar serta-merta. Buka semula daripada Skrin Utama; pelayan penstriman dimulakan semula dengannya."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Agad na nagsasara ang app. Buksan itong muli mula sa Home Screen; muling magsi-start ang streaming server kasabay nito."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "برنامه بلافاصله بسته می‌شود. آن را دوباره از صفحه خانه باز کنید؛ سرور پخش جریانی همراه آن دوباره راه‌اندازی می‌شود."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "অ্যাপটি সঙ্গে সঙ্গে বন্ধ হয়ে যায়। হোম স্ক্রিন থেকে এটি আবার খুলুন; স্ট্রিমিং সার্ভার এর সঙ্গে পুনরায় চালু হয়।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "ஆப் உடனடியாக வெளியேறும். அதை முகப்புத் திரையிலிருந்து மீண்டும் திறக்கவும்; ஸ்ட்ரீமிங் சர்வர் அதனுடன் மறுதொடக்கம் செய்யும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "యాప్ వెంటనే మూసివేయబడుతుంది. హోమ్ స్క్రీన్ నుండి దాన్ని మళ్లీ తెరవండి; దానితో పాటు స్ట్రీమింగ్ సర్వర్ రీస్టార్ట్ అవుతుంది."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "अॅप लगेच बंद होते. ते Home Screen वरून पुन्हा उघडा; streaming सर्व्हर त्यासोबत पुन्हा सुरू होतो."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "એપ તરત જ બંધ થાય છે. તેને Home Screen પરથી ફરી ખોલો; સ્ટ્રીમિંગ સર્વર તેની સાથે ફરી શરૂ થાય છે."
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಆ್ಯಪ್ ತಕ್ಷಣ ಮುಚ್ಚುತ್ತದೆ. ಅದನ್ನು ಹೋಮ್ ಸ್ಕ್ರೀನ್‌ನಿಂದ ಮತ್ತೆ ತೆರೆಯಿರಿ; ಸ್ಟ್ರೀಮಿಂಗ್ ಸರ್ವರ್ ಅದರೊಂದಿಗೆ ಮರುಪ್ರಾರಂಭವಾಗುತ್ತದೆ."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "ആപ്പ് ഉടനടി അടയ്ക്കുന്നു. ഹോം സ്ക്രീനിൽ നിന്ന് അത് വീണ്ടും തുറക്കുക; സ്ട്രീമിംഗ് സെർവർ അതോടൊപ്പം റീസ്റ്റാർട്ട് ചെയ്യുന്നു."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ایپ فوراً بند ہو جاتی ہے۔ اسے ہوم اسکرین سے دوبارہ کھولیں؛ اسٹریمنگ سرور اس کے ساتھ دوبارہ شروع ہو جاتا ہے۔"
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplikácia sa okamžite ukončí. Otvorte ju znova z plochy; streamovací server sa s ňou reštartuje."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Приложението се затваря веднага. Отворете го отново от началния екран; стрийминг сървърът се рестартира с него."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplikacija se odmah zatvara. Otvorite je ponovno s početnog zaslona; poslužitelj za streaming pokreće se s njom."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Апликација се одмах затвара. Отворите је поново са почетног екрана; сервер за стримовање се поново покреће с њом."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplikacija se takoj zapre. Znova jo odprite z začetnega zaslona; pretočni strežnik se zažene z njo."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Programa iškart išsijungia. Atverkite ją iš naujo pradžios ekrane; srautinio perdavimo serveris paleidžiamas kartu su ja."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lietotne tūlīt aizveras. Atveriet to vēlreiz no sākuma ekrāna; straumēšanas serveris restartējas kopā ar to."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Rakendus sulgub kohe. Ava see uuesti Avakuvalt; voogedastusserver taaskäivitub koos sellega."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "L'app es tanca immediatament. Torna a obrir-la des de la pantalla d'inici; el servidor de streaming es reinicia amb ella."
          }
        },
        "gl": {
          "stringUnit": {
            "state": "translated",
            "value": "A app péchase de inmediato. Ábrena de novo desde a pantalla de inicio; o servidor de transmisión reiníciase con ela."
          }
        },
        "eu": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplikazioa berehala irteten da. Ireki berriz Hasierako Pantailatik; streaming zerbitzaria berrekin egiten da."
          }
        },
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Die app sluit onmiddellik. Maak dit weer oop vanaf die tuisskerm; die stromingbediener herbegin saam daarmee."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Tətbiq dərhal çıxır. Ana ekrandan yenidən açın; axın serveri onunla birlikdə yenidən başlayır."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplikacioni mbyllet menjëherë. Hapeni sërish nga Ekrani Kryesor; serveri i transmetimit riniset me të."
          }
        },
        "is": {
          "stringUnit": {
            "state": "translated",
            "value": "Forritið hættir strax. Opnaðu það aftur frá heimaskjánum; streymisþjónninn endurræsist með því."
          }
        },
        "mk": {
          "stringUnit": {
            "state": "translated",
            "value": "Апликацијата веднаш се затвора. Повторно отворете ја од почетниот екран; серверот за стримување повторно се стартува со неа."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Programu inafunga mara moja. Ifungue tena kutoka kwenye Skrini ya Nyumbani; seva ya mtiririko inaanza upya nayo."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Қосымша бірден жабылады. Оны басты экраннан қайта ашыңыз; ағын серверы онымен бірге қайта іске қосылады."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Ծրագիրն անմիջապես կփակվի։ Բացեք այն կրկին Գլխավոր էկրանից. հոսման սերվերն ու ծրագիրը կվերագործարկվի։"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "translated",
            "value": "აპლიკაცია დაუყოვნებლივ იხურება. გახსენით ხელახლა მთავარი ეკრანიდან; სტრიმინგ სერვერი ერთად გადაიტვირთება."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਐਪ ਤੁਰੰਤ ਬੰਦ ਹੋ ਜਾਂਦੀ ਹੈ। ਹੋਮ ਸਕਰੀਨ ਤੋਂ ਇਸਨੂੰ ਦੁਬਾਰਾ ਖੋਲ੍ਹੋ; ਸਟ੍ਰੀਮਿੰਗ ਸਰਵਰ ਇਸਦੇ ਨਾਲ ਮੁੜ ਸ਼ੁਰੂ ਹੁੰਦਾ ਹੈ।"
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "एप तुरुन्तै बन्द हुन्छ। होम स्क्रिनबाट फेरि खोल्नुहोस्; स्ट्रिमिङ सर्भर यससँगै पुनः सुरु हुन्छ।"
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "መተግበሪያው ወዲያው ይዘጋሉ። ከቤት ስክሪን ዳግም ይክፈቱ፤ ዥረቱ አገልጋይ ከእሱ ጋር ዳግም ይጀምራሉ።"
          }
        },
        "km": {
          "stringUnit": {
            "state": "translated",
            "value": "កម្មវិធីបិទភ្លាម។ បើកវាឡើងវិញពី Home Screen; streaming server ចាប់ផ្តើមឡើងវិញជាមួយវា។"
          }
        }
      }
    },
    "The main profile. It uses your Stremio account's own watch history, like before profiles existed.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il profilo principale. Usa la cronologia di visione del tuo account Stremio, come prima che esistessero i profili."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El perfil principal. Usa el propio historial de visualización de tu cuenta Stremio, como antes de que existieran los perfiles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le profil principal. Il utilise l'historique de visionnage propre à votre compte Stremio, comme avant l'existence des profils."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Hauptprofil. Es verwendet den eigenen Wiedergabeverlauf deines Stremio-Kontos, wie vor der Einführung von Profilen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O perfil principal. Ele usa o histórico de exibição da sua própria conta Stremio, como antes de os perfis existirem."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メインのプロファイルです。プロファイルが存在する前と同じように、Stremio アカウント独自の視聴履歴を使用します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기본 프로필입니다. 프로필이 존재하기 전과 마찬가지로 Stremio 계정 자체의 시청 기록을 사용합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "主配置文件。它使用你的 Stremio 账户自己的观看历史，就像配置文件出现之前那样。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Основной профиль. Он использует собственную историю просмотра вашего аккаунта Stremio, как было до появления профилей."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मुख्य प्रोफ़ाइल। यह आपके Stremio खाते का अपना देखने का इतिहास उपयोग करती है, जैसे प्रोफ़ाइलें होने से पहले होता था।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الملف الشخصي الرئيسي. يستخدم سجل المشاهدة الخاص بحساب Stremio الخاص بك، كما كان قبل وجود الملفات الشخصية."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ana profil. Profiller var olmadan önceki gibi, Stremio hesabınızın kendi izleme geçmişini kullanır."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O perfil principal. Usa o histórico de visualização da sua própria conta Stremio, como antes de existirem perfis."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het hoofdprofiel. Het gebruikt de eigen kijkgeschiedenis van je Stremio-account, net zoals voordat er profielen bestonden."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Główny profil. Korzysta z własnej historii oglądania Twojego konta Stremio, jak przed pojawieniem się profili."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Huvudprofilen. Den använder ditt Stremio-kontos egna tittarhistorik, som innan profiler fanns."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "主要設定檔。它使用你 Stremio 帳號本身的觀看記錄，就像還沒有設定檔之前一樣。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Profil utama. Ini menggunakan riwayat tonton milik akun Stremio Anda sendiri, seperti sebelum profil ada."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "โปรไฟล์หลัก ใช้ประวัติการดูของบัญชี Stremio ของคุณเอง เหมือนตอนที่ยังไม่มีโปรไฟล์"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Hồ sơ chính. Nó dùng lịch sử xem riêng của tài khoản Stremio của bạn, như trước khi có hồ sơ."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Основний профіль. Він використовує власну історію перегляду вашого акаунта Stremio, як було до появи профілів."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Hlavní profil. Používá vlastní historii sledování vašeho účtu Stremio, jako předtím, než profily existovaly."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το κύριο προφίλ. Χρησιμοποιεί το ιστορικό παρακολούθησης του ίδιου του λογαριασμού Stremio σας, όπως πριν υπάρξουν τα προφίλ."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הפרופיל הראשי. הוא משתמש בהיסטוריית הצפייה של חשבון Stremio שלך, כמו לפני שהיו פרופילים."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hovedprofilen. Den bruger din Stremio-kontos egen seehistorik, ligesom før profiler fandtes."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pääprofiili. Se käyttää Stremio-tilisi omaa katseluhistoriaa, kuten ennen profiilien olemassaoloa."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hovedprofilen. Den bruker Stremio-kontoens egen avspillingshistorikk, slik det var før profiler fantes."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Profilul principal. Folosește propriul istoric de vizionare al contului tău Stremio, ca înainte de a exista profilurile."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A fő profil. A Stremio-fiókod saját megtekintési előzményeit használja, ahogyan a profilok létezése előtt."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Profil utama. Ia menggunakan sejarah tontonan akaun Stremio anda sendiri, seperti sebelum profil wujud."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Ang pangunahing profile. Ginagamit nito ang sariling watch history ng iyong Stremio account, gaya noong wala pang profile."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "نمایه اصلی. از تاریخچه تماشای خودِ حساب Stremio شما استفاده می‌کند، مانند زمانی که نمایه‌ها وجود نداشتند."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "প্রধান প্রোফাইল। প্রোফাইল থাকার আগের মতোই, এটি আপনার Stremio অ্যাকাউন্টের নিজের দেখার ইতিহাস ব্যবহার করে।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "முதன்மைச் சுயவிவரம். சுயவிவரங்கள் இருந்த முன்பு போலவே, இது உங்கள் Stremio கணக்கின் சொந்த பார்வை வரலாற்றைப் பயன்படுத்துகிறது."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ప్రధాన ప్రొఫైల్. ఇది మీ Stremio ఖాతా స్వంత చూసిన చరిత్రను వాడుతుంది, ప్రొఫైల్‌లు ఉనికిలోకి రాకముందటిలా."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "मुख्य प्रोफाइल. प्रोफाइल अस्तित्वात येण्यापूर्वी जसे होते तसे, हे तुमच्या Stremio खात्याचा स्वतःचा पाहण्याचा इतिहास वापरते."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "મુખ્ય પ્રોફાઇલ. તે તમારા Stremio account નો પોતાનો જોવાનો ઇતિહાસ વાપરે છે, જેમ પ્રોફાઇલ અસ્તિત્વમાં આવ્યા પહેલાં હતું."
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಮುಖ್ಯ ಪ್ರೊಫೈಲ್. ಪ್ರೊಫೈಲ್‌ಗಳು ಇರುವ ಮೊದಲಿನಂತೆ, ಇದು ನಿಮ್ಮ Stremio ಖಾತೆಯ ಸ್ವಂತ ವೀಕ್ಷಣಾ ಇತಿಹಾಸವನ್ನು ಬಳಸುತ್ತದೆ."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "പ്രധാന പ്രൊഫൈൽ. പ്രൊഫൈലുകൾ നിലവിലുണ്ടാകുന്നതിന് മുമ്പുള്ളതുപോലെ, ഇത് നിങ്ങളുടെ Stremio അക്കൗണ്ടിന്റെ സ്വന്തം കാഴ്ച ചരിത്രം ഉപയോഗിക്കുന്നു."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "مرکزی پروفائل۔ یہ آپ کے Stremio اکاؤنٹ کی اپنی دیکھنے کی تاریخ استعمال کرتا ہے، جیسے پروفائلز کے وجود میں آنے سے پہلے تھا۔"
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Hlavný profil. Používa vlastnú históriu sledovania vášho účtu Stremio, ako pred existenciou profilov."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Основният профил. Той използва собствената история на гледане на вашия Stremio акаунт, както преди да съществуват профили."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Glavni profil. Koristi vlastitu povijest gledanja vašeg Stremio računa, kao prije postojanja profila."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Главни профил. Користи сопствену историју гледања вашег Stremio налога, као пре него што су профили постојали."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Glavni profil. Uporablja zgodovino gledanja vašega računa Stremio, kot je bilo pred obstojem profilov."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Pagrindinis profilis. Jis naudoja jūsų Stremio paskyros žiūrėjimo istoriją, kaip prieš atsirandant profiliams."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Galvenais profils. Tas izmanto jūsu Stremio konta paša skatīšanās vēsturi, tāpat kā pirms profilu pastāvēšanas."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Põhiprofiil. See kasutab su Stremio konto enda vaatamisajalugu, nagu enne profiilide olemasolu."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "El perfil principal. Utilitza l'historial de visualització propi del teu compte de Stremio, com abans d'existir els perfils."
          }
        },
        "gl": {
          "stringUnit": {
            "state": "translated",
            "value": "O perfil principal. Usa o historial de visualización da túa conta de Stremio, como antes de que existisen os perfís."
          }
        },
        "eu": {
          "stringUnit": {
            "state": "translated",
            "value": "Profil nagusia. Stremio kontuaren ikusteko historia propioa erabiltzen du, profilak existitu baino lehen bezala."
          }
        },
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Die hoofprofiel. Dit gebruik jou Stremio-rekening se eie kykvorderings, soos voor profiele bestaan het."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Əsas profil. Profillər mövcud olmadan əvvəlki kimi öz Stremio hesabınızın izlənmə tarixçəsindən istifadə edir."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Profili kryesor. Përdor historinë e shikimit të llogarisë suaj Stremio, si para se profilet të ekzistonin."
          }
        },
        "is": {
          "stringUnit": {
            "state": "translated",
            "value": "Aðalprófíllinn. Hann notar eigin horfuferil Stremio-reikningsins þíns, eins og áður en prófílar voru."
          }
        },
        "mk": {
          "stringUnit": {
            "state": "translated",
            "value": "Главниот профил. Ја користи сопствената историја на гледање на вашата Stremio сметка, како пред да постоеле профили."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Wasifu mkuu. Unatumia historia ya kutazama ya akaunti yako ya Stremio yenyewe, kama ilivyokuwa kabla ya wasifu kuwepo."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Негізгі профиль. Бұл профильдер пайда болғанға дейінгідей Stremio тіркелгіңіздің жеке қараушы тарихын пайдаланады."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Հիմնական պրոֆիլ։ Այն օգտագործում է ձեր Stremio հաշվի սեփական դիտման պատմությունը, ինչպես մինչ պրոֆիլների ստեղծումը։"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "translated",
            "value": "მთავარი პროფილი. ის იყენებს Stremio ანგარიშის საკუთარ ყურების ისტორიას, ისევე, როგორც პროფილების არსებობამდე."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਮੁੱਖ ਪ੍ਰੋਫ਼ਾਈਲ। ਇਹ ਤੁਹਾਡੇ Stremio ਖਾਤੇ ਦਾ ਆਪਣਾ ਵੇਖਣ ਇਤਿਹਾਸ ਵਰਤਦੀ ਹੈ, ਜਿਵੇਂ ਪ੍ਰੋਫ਼ਾਈਲਾਂ ਤੋਂ ਪਹਿਲਾਂ ਸੀ।"
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "मुख्य प्रोफाइल। यसले तपाईंको Stremio खाताको आफ्नै हेर्ने इतिहास प्रयोग गर्छ, जसरी प्रोफाइल अस्तित्वमा आउनु अगाडि थियो।"
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "ዋናው መገለጫ። ከ Stremio መለያ የራሱ የሰዓት ታሪክ ይጠቀማሉ፣ ከቀደም እንደነበሩ።"
          }
        },
        "km": {
          "stringUnit": {
            "state": "translated",
            "value": "ប្រវត្តិរូបចម្បង។ វាប្រើប្រវត្តិមើលផ្ទាល់ខ្លួនរបស់គណនី Stremio របស់អ្នក ដូចមុនពេលប្រវត្តិរូបមានសារ៍ស្ទូ។"
          }
        }
      }
    },
    "The player auto-picks these when a title starts. Forced shows only foreign-dialogue captions; Always shows full subtitles in your language. Foreign-language titles always get full subtitles so you can follow.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il lettore li seleziona automaticamente all'avvio di un titolo. Forzati mostra solo i sottotitoli dei dialoghi in lingua straniera; Sempre mostra i sottotitoli completi nella tua lingua. I titoli in lingua straniera ricevono sempre i sottotitoli completi così puoi seguirli."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El reproductor los selecciona automáticamente al empezar un título. Forzados muestra solo los subtítulos de diálogos en idioma extranjero; Siempre muestra los subtítulos completos en tu idioma. Los títulos en idioma extranjero siempre reciben subtítulos completos para que puedas seguirlos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le lecteur les sélectionne automatiquement au démarrage d'un titre. Forcés affiche uniquement les sous-titres des dialogues en langue étrangère ; Toujours affiche les sous-titres complets dans votre langue. Les titres en langue étrangère reçoivent toujours des sous-titres complets pour que vous puissiez suivre."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Player wählt diese automatisch aus, wenn ein Titel startet. „Erzwungen“ zeigt nur Untertitel für fremdsprachige Dialoge; „Immer“ zeigt vollständige Untertitel in deiner Sprache. Fremdsprachige Titel erhalten immer vollständige Untertitel, damit du folgen kannst."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O player escolhe estas automaticamente quando um título inicia. Forçadas mostra apenas as legendas de diálogos em outros idiomas; Sempre mostra legendas completas no seu idioma. Títulos em idioma estrangeiro sempre recebem legendas completas para você acompanhar."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タイトル開始時にプレーヤーがこれらを自動選択します。「強制」は外国語のセリフのキャプションのみを表示し、「常に」は使用言語のフル字幕を表示します。外国語のタイトルには、内容を追えるよう常にフル字幕が表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "플레이어는 작품이 시작될 때 이를 자동으로 선택합니다. 강제는 외국어 대사 자막만 표시하고, 항상은 사용 언어로 전체 자막을 표시합니다. 외국어 작품은 따라갈 수 있도록 항상 전체 자막이 표시됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "播放器在影片开始时会自动选择这些。强制只显示外语对白字幕；始终会以你的语言显示完整字幕。外语影片始终会获得完整字幕，以便你跟上剧情。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Плеер автоматически выбирает их при запуске тайтла. «Форсированные» показывают только субтитры для иностранной речи; «Всегда» показывает полные субтитры на вашем языке. Иноязычные тайтлы всегда получают полные субтитры, чтобы вы могли следить за сюжетом."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "टाइटल शुरू होने पर प्लेयर इन्हें स्वतः चुन लेता है। बाध्य केवल विदेशी-संवाद के कैप्शन दिखाता है; हमेशा आपकी भाषा में पूरे सबटाइटल दिखाता है। विदेशी-भाषा वाले टाइटल को हमेशा पूरे सबटाइटल मिलते हैं ताकि आप समझ सकें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يختار المشغّل هذه تلقائيًا عند بدء عنوان. يعرض الوضع المفروض تعليقات الحوار الأجنبي فقط؛ ويعرض الوضع الدائم الترجمة الكاملة بلغتك. تحصل العناوين الأجنبية اللغة دائمًا على ترجمة كاملة لتتمكن من المتابعة."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir başlık başladığında oynatıcı bunları otomatik seçer. Zorunlu yalnızca yabancı diyalog altyazılarını gösterir; Her Zaman ise kendi dilinizde tam altyazıları gösterir. Yabancı dildeki başlıklar takip edebilmeniz için her zaman tam altyazı alır."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O leitor escolhe estas automaticamente quando um título começa. Forçadas mostra apenas as legendas de diálogos em língua estrangeira; Sempre mostra legendas completas no seu idioma. Os títulos em língua estrangeira recebem sempre legendas completas para que possa acompanhar."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De speler kiest deze automatisch wanneer een titel start. Geforceerd toont alleen ondertitels voor vreemdtalige dialogen; Altijd toont volledige ondertiteling in jouw taal. Vreemdtalige titels krijgen altijd volledige ondertiteling zodat je het kunt volgen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odtwarzacz dobiera je automatycznie po uruchomieniu tytułu. Wymuszone pokazuje tylko napisy do obcojęzycznych dialogów; Zawsze pokazuje pełne napisy w Twoim języku. Tytuły obcojęzyczne zawsze otrzymują pełne napisy, abyś mógł śledzić akcję."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Spelaren väljer dessa automatiskt när en titel startar. Forcerade visar bara undertexter för främmande dialog; Alltid visar fullständiga undertexter på ditt språk. Titlar på främmande språk får alltid fullständiga undertexter så att du kan följa med."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "播放器會在片名開始時自動挑選這些。「強制」只顯示外語對白的字幕；「一律」則顯示你語言的完整字幕。外語片名一律會取得完整字幕，讓你能跟上劇情。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pemutar memilih ini secara otomatis saat judul dimulai. Forced hanya menampilkan teks dialog bahasa asing; Selalu menampilkan subtitle penuh dalam bahasa Anda. Judul berbahasa asing selalu mendapat subtitle penuh agar Anda dapat mengikutinya."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ตัวเล่นจะเลือกสิ่งเหล่านี้โดยอัตโนมัติเมื่อเรื่องเริ่มเล่น บังคับจะแสดงเฉพาะคำบรรยายบทสนทนาภาษาต่างประเทศ เสมอจะแสดงคำบรรยายเต็มในภาษาของคุณ เรื่องภาษาต่างประเทศจะได้คำบรรยายเต็มเสมอเพื่อให้คุณติดตามได้"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Trình phát tự động chọn các mục này khi một tựa đề bắt đầu. Bắt buộc chỉ hiển thị phụ đề cho lời thoại tiếng nước ngoài; Luôn hiển thị phụ đề đầy đủ bằng ngôn ngữ của bạn. Các tựa đề tiếng nước ngoài luôn được hiển thị phụ đề đầy đủ để bạn theo dõi được."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Плеєр автоматично вибирає їх на старті тайтлу. Примусові показують лише підписи до іншомовних діалогів; Завжди показують повні субтитри вашою мовою. Іншомовні тайтли завжди отримують повні субтитри, щоб ви могли стежити."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přehrávač je při spuštění titulu vybere automaticky. Vynucené zobrazí jen titulky cizojazyčných dialogů; Vždy zobrazí plné titulky ve vašem jazyce. Cizojazyčné tituly vždy dostanou plné titulky, abyste je mohli sledovat."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η αναπαραγωγή τα επιλέγει αυτόματα όταν ξεκινά ένας τίτλος. Το Εξαναγκασμένο εμφανίζει μόνο λεζάντες ξενόγλωσσων διαλόγων· το Πάντα εμφανίζει πλήρεις υπότιτλους στη γλώσσα σας. Οι ξενόγλωσσοι τίτλοι λαμβάνουν πάντα πλήρεις υπότιτλους ώστε να μπορείτε να παρακολουθήσετε."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הנגן בוחר אותם אוטומטית כשכותר מתחיל. כפוי מציג רק כתוביות לדיאלוג בשפה זרה; תמיד מציג כתוביות מלאות בשפה שלך. כותרים בשפה זרה תמיד מקבלים כתוביות מלאות כדי שתוכל לעקוב."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Afspilleren vælger automatisk disse, når en titel starter. Tvungen viser kun undertekster til fremmedsproget dialog; Altid viser fulde undertekster på dit sprog. Fremmedsprogede titler får altid fulde undertekster, så du kan følge med."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Soitin valitsee nämä automaattisesti, kun nimike käynnistyy. Pakotettu näyttää vain vieraskielisen dialogin tekstitykset; Aina näyttää täydet tekstitykset kielelläsi. Vieraskieliset nimikkeet saavat aina täydet tekstitykset, jotta pysyt mukana."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Spilleren velger disse automatisk når en tittel starter. Tvungen viser bare undertekster for fremmedspråklig dialog; Alltid viser fulle undertekster på ditt språk. Fremmedspråklige titler får alltid fulle undertekster så du kan følge med."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Playerul le alege automat când pornește un titlu. Forțate afișează doar subtitrările pentru dialogul străin; Întotdeauna afișează subtitrări complete în limba ta. Titlurile în limbi străine primesc întotdeauna subtitrări complete ca să le poți urmări."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A lejátszó automatikusan ezeket választja egy cím indításakor. A Kényszerített csak az idegen nyelvű párbeszédek feliratait mutatja; a Mindig a teljes feliratot a nyelveden. Az idegen nyelvű címek mindig teljes feliratot kapnak, hogy követhesd."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pemain memilih ini secara automatik apabila tajuk bermula. Dipaksa menunjukkan hanya kapsyen dialog asing; Sentiasa menunjukkan sari kata penuh dalam bahasa anda. Tajuk bahasa asing sentiasa mendapat sari kata penuh supaya anda boleh mengikuti."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Awtomatikong pinipili ng player ang mga ito kapag nagsimula ang isang titulo. Ipinapakita ng Forced ang mga caption para lamang sa banyagang dialogo; Ipinapakita ng Always ang buong subtitle sa iyong wika. Ang mga titulong banyaga ang wika ay palaging may buong subtitle para makasunod ka."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "پخش‌کننده هنگام شروع یک عنوان، این‌ها را به‌طور خودکار انتخاب می‌کند. اجباری فقط زیرنویس گفت‌وگوهای خارجی را نشان می‌دهد؛ همیشه زیرنویس کامل را به زبان شما نشان می‌دهد. عنوان‌های با زبان خارجی همیشه زیرنویس کامل دریافت می‌کنند تا بتوانید دنبال کنید."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "কোনো শিরোনাম শুরু হলে প্লেয়ার এগুলো স্বয়ংক্রিয়ভাবে বেছে নেয়। Forced শুধু বিদেশি-সংলাপের ক্যাপশন দেখায়; Always আপনার ভাষায় সম্পূর্ণ সাবটাইটেল দেখায়। বিদেশি-ভাষার শিরোনাম সবসময় সম্পূর্ণ সাবটাইটেল পায় যাতে আপনি অনুসরণ করতে পারেন।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "தலைப்பு தொடங்கும்போது பிளேயர் இவற்றைத் தானாகத் தேர்ந்தெடுக்கும். கட்டாயம் வெளிநாட்டு-உரையாடல் வசன வரிகளை மட்டும் காட்டும்; எப்போதும் உங்கள் மொழியில் முழு வசன வரிகளைக் காட்டும். வெளிமொழித் தலைப்புகளுக்கு நீங்கள் பின்தொடரும்படி எப்போதும் முழு வசன வரிகள் கிடைக்கும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "టైటిల్ ప్రారంభమైనప్పుడు ప్లేయర్ వీటిని స్వయంచాలకంగా ఎంచుకుంటుంది. Forced విదేశీ-సంభాషణ క్యాప్షన్‌లను మాత్రమే చూపుతుంది; Always మీ భాషలో పూర్తి సబ్‌టైటిల్‌లను చూపుతుంది. విదేశీ-భాషా టైటిల్‌లకు మీరు అనుసరించగలిగేలా ఎల్లప్పుడూ పూర్తి సబ్‌టైటిల్‌లు వస్తాయి."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "शीर्षक सुरू होताना प्लेअर हे आपोआप निवडतो. Forced फक्त परदेशी-संवादाची कॅप्शन दाखवते; Always तुमच्या भाषेतील संपूर्ण उपशीर्षके दाखवते. परदेशी-भाषेतील शीर्षकांना नेहमी संपूर्ण उपशीर्षके मिळतात जेणेकरून तुम्ही समजू शकाल."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "શીર્ષક શરૂ થાય ત્યારે પ્લેયર આ આપમેળે પસંદ કરે છે. Forced ફક્ત વિદેશી-સંવાદના કૅપ્શન બતાવે છે; Always તમારી ભાષામાં સંપૂર્ણ સબટાઇટલ બતાવે છે. વિદેશી-ભાષાના શીર્ષકોને હંમેશા સંપૂર્ણ સબટાઇટલ મળે છે જેથી તમે સમજી શકો."
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಶೀರ್ಷಿಕೆ ಪ್ರಾರಂಭವಾದಾಗ ಪ್ಲೇಯರ್ ಇವುಗಳನ್ನು ಸ್ವಯಂ-ಆಯ್ಕೆ ಮಾಡುತ್ತದೆ. ಫೋರ್ಸ್ಡ್ ವಿದೇಶಿ-ಸಂಭಾಷಣೆಯ ಕ್ಯಾಪ್ಶನ್‌ಗಳನ್ನು ಮಾತ್ರ ತೋರಿಸುತ್ತದೆ; ಯಾವಾಗಲೂ ನಿಮ್ಮ ಭಾಷೆಯಲ್ಲಿ ಪೂರ್ಣ ಸಬ್‌ಟೈಟಲ್‌ಗಳನ್ನು ತೋರಿಸುತ್ತದೆ. ವಿದೇಶಿ-ಭಾಷೆಯ ಶೀರ್ಷಿಕೆಗಳಿಗೆ ಯಾವಾಗಲೂ ಪೂರ್ಣ ಸಬ್‌ಟೈಟಲ್‌ಗಳು ಸಿಗುತ್ತವೆ ಇದರಿಂದ ನೀವು ಅನುಸರಿಸಬಹುದು."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "ഒരു ടൈറ്റിൽ ആരംഭിക്കുമ്പോൾ പ്ലെയർ ഇവ സ്വയമേവ തിരഞ്ഞെടുക്കുന്നു. Forced വിദേശ-സംഭാഷണ ക്യാപ്ഷനുകൾ മാത്രം കാണിക്കുന്നു; Always നിങ്ങളുടെ ഭാഷയിലെ പൂർണ്ണ സബ്ടൈറ്റിലുകൾ കാണിക്കുന്നു. വിദേശ-ഭാഷാ ടൈറ്റിലുകൾക്ക് നിങ്ങൾക്ക് പിന്തുടരാൻ കഴിയുന്ന വിധം എപ്പോഴും പൂർണ്ണ സബ്ടൈറ്റിലുകൾ ലഭിക്കും."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "عنوان شروع ہونے پر پلیئر انہیں خود بخود منتخب کرتا ہے۔ مجبوری صرف غیر ملکی-مکالمے کے کیپشنز دکھاتی ہے؛ ہمیشہ آپ کی زبان میں مکمل سب ٹائٹلز دکھاتی ہے۔ غیر ملکی زبان کے عنوانات کو ہمیشہ مکمل سب ٹائٹلز ملتے ہیں تاکہ آپ سمجھ سکیں۔"
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Prehrávač ich automaticky vyberie pri spustení titulu. Vynútené zobrazuje len titulky cudzojazyčných dialógov; Vždy zobrazuje plné titulky vo vašom jazyku. Cudzojazyčné tituly vždy dostanú plné titulky, aby ste ich mohli sledovať."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Плейърът избира автоматично тези при стартиране на заглавие. Принудителни показва само надписи за чуждоезични диалози; Винаги показва пълни субтитри на вашия език. Чуждоезичните заглавия винаги получават пълни субтитри, за да можете да следите."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Player ih automatski odabire kad naslov krene. Prisilno prikazuje samo titlove dijaloga na stranom jeziku; Uvijek prikazuje pune titlove na vašem jeziku. Naslovi na stranom jeziku uvijek dobivaju pune titlove kako biste mogli pratiti."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Плејер их аутоматски бира када наслов почне. Принудни приказује само титлове за дијалоге на страном језику; Увек приказује пуне титлове на вашем језику. Наслови на страном језику увек добијају пуне титлове како бисте могли да пратите."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Predvajalnik te samodejno izbere ob zagonu naslova. Vsiljeno prikaže samo napise tujih dialogov; Vedno prikaže polne podnapise v vašem jeziku. Tujejezični naslovi vedno dobijo polne podnapise, da lahko sledite."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Grotuvas automatiškai juos parenka paleidus kūrinį. Priverstiniai rodo tik užsienio kalbos dialogų subtitrus; Visada rodo pilnus subtitrus jūsų kalba. Užsienio kalbos kūriniai visada gauna pilnus subtitrus, kad galėtumėte sekti."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Atskaņotājs tos automātiski izvēlas, kad sākas nosaukums. Piespiestie rāda tikai svešvalodas dialogu parakstus; Vienmēr rāda pilnus subtitrus jūsu valodā. Svešvalodu nosaukumi vienmēr saņem pilnus subtitrus, lai jūs varētu sekot līdzi."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Mängija valib need automaatselt, kui pealkiri käivitub. Sundtud kuvab ainult võõrkeelse dialoogi subtiitrid; Alati kuvab täissubtiitrid su keeles. Võõrkeelsed pealkirjad saavad alati täissubtiitrid, et saaksid järge pidada."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "El reproductor selecciona automàticament aquests quan s'inicia un títol. Forçat mostra només els subtítols de diàleg en llengua estrangera; Sempre mostra els subtítols complets en el teu idioma. Els títols en llengua estrangera sempre reben subtítols complets perquè puguis seguir-los."
          }
        },
        "gl": {
          "stringUnit": {
            "state": "translated",
            "value": "O reprodutor escolle automaticamente estas opcións cando comeza un título. Forzado mostra só os subtítulos de diálogos estranxeiros; Sempre mostra subtítulos completos no teu idioma. Os títulos en idioma estranxeiro sempre teñen subtítulos completos para que os poidas seguir."
          }
        },
        "eu": {
          "stringUnit": {
            "state": "translated",
            "value": "Erreproduzitzaileak automatikoki hautatzen ditu hauek titulu bat hasten denean. Behartuak atzerriko elkarrizketaren azpitituluak soilik erakusten ditu; Beti zure hizkuntzan azpitituluak erakusten ditu. Atzerriko hizkuntzetako tituluek beti azpititulu osoak jasotzen dituzte jarraitu ahal izateko."
          }
        },
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Die speler kies hierdie outomaties wanneer 'n titel begin. Forseer wys slegs byskrifte vir buitelandse dialoog; Altyd wys volledige onderskrifte in jou taal. Buitelanders-taal titels kry altyd volledige onderskrifte sodat jy kan volg."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Oynatıcı, bir başlıq başladığında bunları avtomatik seçir. Məcburi yalnız xarici dialoqun altyazılarını göstərir; Həmişə dilinizde tam altyazılar göstərir. Xarici dilli başlıqlarda izləyə biləsiniz deyə həmişə tam altyazılar olur."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Luajtësi i zgjedh automatikisht këto kur fillon një titull. E Detyruar tregon vetëm titrat e dialogut të huaj; Gjithmonë tregon titrat e plota në gjuhën tuaj. Titujt në gjuhë të huaj marrin gjithmonë titrat e plota që ta ndiqni."
          }
        },
        "is": {
          "stringUnit": {
            "state": "translated",
            "value": "Spilarinn velur þessa sjálfkrafa þegar titill byrjar. Þvingað sýnir aðeins texta fyrir erlend samræður; Alltaf sýnir fulla skjátexta á tungumálinu þínu. Titlar á erlendum tungumálum fá alltaf fulla skjátexta svo þú getir fylgst með."
          }
        },
        "mk": {
          "stringUnit": {
            "state": "translated",
            "value": "Плеерот автоматски ги избира овие кога започнува наслов. Принудно прикажува само титлови за странски дијалог; Секогаш прикажува целосни титлови на вашиот јазик. Насловите на странски јазик секогаш добиваат целосни титлови за да можете да следите."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Mchezaji huchagua hizi otomatiki wakati kichwa kinapoanza. Iliyolazimishwa inaonyesha manukuu ya mazungumzo ya kigeni peke yake; Daima inaonyesha manukuu kamili katika lugha yako. Vichwa vya lugha ya kigeni daima huwa na manukuu kamili ili uweze kufuatilia."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ойнатқыш атау басталғанда осыларды автоматты таңдайды. Мәжбүрлі тек шетел диалог субтитрлерін көрсетеді; Әрдайым тіліңіздегі толық субтитрлерді көрсетеді. Шет тіліндегі атаулар барлық уақытта толық субтитрлер алады."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Նվագարկիչն ավտոմատ ընտրում է սրանք, երբ վերնագիրը սկսվում է։ «Հարկադիր»-ը ցուցադրում է միայն արտաքին երկխոսության ենթագրեր. «Միշտ»-ը ձեր լեզվով ամբողջ ենթագրեր է ցուցադրում։ Արտասահմանյան լեզվի վերնագրերն ամբողջ ենթագրեր են ստանում, որ կարողանաք հետևել։"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "translated",
            "value": "პლეერი ავტომატურად ირჩევს მათ სათაურის დაწყებისას. იძულებითი აჩვენებს მხოლოდ უცხოური დიალოგის წარწერებს; ყოველთვის აჩვენებს სრულ სუბტიტრებს თქვენ ენაზე. უცხოური ენის სათაურები ყოველთვის ღებულობს სრულ სუბტიტრებს გასაგებად."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਪਲੇਅਰ ਇਹਨਾਂ ਨੂੰ ਆਪਣੇ ਆਪ ਚੁਣਦਾ ਹੈ ਜਦੋਂ ਕੋਈ ਸਿਰਲੇਖ ਸ਼ੁਰੂ ਹੁੰਦਾ ਹੈ। ਲਾਜ਼ਮੀ ਸਿਰਫ਼ ਵਿਦੇਸ਼ੀ-ਸੰਵਾਦ ਕੈਪਸ਼ਨ ਦਿਖਾਉਂਦਾ ਹੈ; ਹਮੇਸ਼ਾ ਤੁਹਾਡੀ ਭਾਸ਼ਾ ਵਿੱਚ ਪੂਰੇ ਸਬਟਾਈਟਲ ਦਿਖਾਉਂਦਾ ਹੈ। ਵਿਦੇਸ਼ੀ ਭਾਸ਼ਾ ਦੇ ਸਿਰਲੇਖਾਂ ਨੂੰ ਹਮੇਸ਼ਾ ਪੂਰੇ ਸਬਟਾਈਟਲ ਮਿਲਦੇ ਹਨ ਤਾਂ ਜੋ ਤੁਸੀਂ ਸਮਝ ਸਕੋ।"
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "शीर्षक सुरु हुँदा प्लेयरले यीहरू स्वचालित रूपमा छनोट गर्छ। Forced ले केवल विदेशी-संवाद क्याप्शन देखाउँछ; Always ले तपाईंको भाषामा पूर्ण उपशीर्षक देखाउँछ। विदेशी-भाषाका शीर्षकहरूले सधैं पूर्ण उपशीर्षक पाउँछन् ताकि तपाईं अनुसरण गर्न सक्नुहोस्।"
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "ርዕሱ ሲጀምር ተጫዋቹ ራስ ሰር ይምረጣቸዋሉ። «ያስፈለገ» ብቻ የውጭ-ቋንቋ ምልክቶችን ያሳያሉ፤ «ሁልጊዜ» ሙሉ ርዕሶቹ በቋንቋዎ ያሳያሉ። የውጭ ቋንቋ ርዕሶች ሁልጊዜ ሙሉ ርዕሶቹ ያገኛሉ ልትከተሉ ትችሉ ዘንድ።"
          }
        },
        "km": {
          "stringUnit": {
            "state": "translated",
            "value": "player ជ្រើសរើសដោយស្វ័យប្រវត្តិទាំងនេះពេលចំណងជើងចាប់ផ្តើម។ Forced បង្ហាញតែចំណងក្រោមការសន្ទនាបរទេស; Always បង្ហាញចំណងក្រោមពេញលេញជាភាសារបស់អ្នក។ ចំណងជើងភាសាបរទេសតែងតែទទួលបានចំណងក្រោមពេញលេញ ដើម្បីឱ្យអ្នកអាចដើរតាម។"
          }
        }
      }
    },
    "This account's profiles differ from this device. Merge both to keep every profile (recommended), or force one side.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I profili di questo account differiscono da quelli di questo dispositivo. Unisci entrambi per mantenere ogni profilo (consigliato), oppure forza un lato."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los perfiles de esta cuenta difieren de los de este dispositivo. Fusiona ambos para conservar todos los perfiles (recomendado), o fuerza un lado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les profils de ce compte diffèrent de ceux de cet appareil. Fusionnez les deux pour conserver tous les profils (recommandé), ou forcez un côté."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Profile dieses Kontos unterscheiden sich von diesem Gerät. Führe beide zusammen, um jedes Profil zu behalten (empfohlen), oder erzwinge eine Seite."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os perfis desta conta diferem dos deste dispositivo. Mescle os dois para manter todos os perfis (recomendado) ou force um dos lados."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このアカウントのプロファイルは、このデバイスと異なります。両方をマージしてすべてのプロファイルを保持する（推奨）か、いずれか一方を強制してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 계정의 프로필이 이 기기와 다릅니다. 모든 프로필을 유지하려면 양쪽을 병합하거나(권장), 한쪽을 강제 적용하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此账户的配置文件与本设备不同。合并双方以保留每个配置文件（推荐），或强制采用一方。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Профили этого аккаунта отличаются от профилей на этом устройстве. Объедините оба, чтобы сохранить все профили (рекомендуется), или принудительно выберите одну сторону."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस खाते की प्रोफ़ाइलें इस डिवाइस से भिन्न हैं। हर प्रोफ़ाइल रखने के लिए दोनों को मर्ज करें (अनुशंसित), या किसी एक पक्ष को बाध्य करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تختلف الملفات الشخصية لهذا الحساب عن هذا الجهاز. ادمج الجانبين للاحتفاظ بكل ملف شخصي (مُوصى به)، أو افرض جانبًا واحدًا."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu hesabın profilleri bu cihazdakinden farklı. Her profili korumak için ikisini birleştirin (önerilir) veya bir tarafı zorlayın."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Os perfis desta conta diferem dos deste dispositivo. Junte ambos para manter todos os perfis (recomendado) ou force um dos lados."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De profielen van dit account verschillen van dit apparaat. Voeg beide samen om elk profiel te behouden (aanbevolen), of forceer één kant."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Profile na tym koncie różnią się od tych na tym urządzeniu. Scal oba, aby zachować każdy profil (zalecane), lub wymuś jedną stronę."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Det här kontots profiler skiljer sig från den här enheten. Slå ihop båda för att behålla alla profiler (rekommenderas), eller tvinga fram en sida."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此帳號的設定檔與此裝置上的不同。可合併兩者以保留每個設定檔（建議），或強制以某一方為準。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Profil akun ini berbeda dari perangkat ini. Gabungkan keduanya untuk menyimpan setiap profil (disarankan), atau paksa salah satu sisi."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "โปรไฟล์ของบัญชีนี้แตกต่างจากอุปกรณ์นี้ ผสานทั้งสองเพื่อเก็บทุกโปรไฟล์ (แนะนำ) หรือบังคับใช้ฝ่ายใดฝ่ายหนึ่ง"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Hồ sơ của tài khoản này khác với thiết bị này. Hợp nhất cả hai để giữ mọi hồ sơ (khuyến nghị), hoặc buộc theo một bên."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Профілі цього акаунта відрізняються від цього пристрою. Об’єднайте обидва, щоб зберегти всі профілі (рекомендовано), або примусово виберіть один бік."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Profily tohoto účtu se liší od tohoto zařízení. Sloučením obou zachováte všechny profily (doporučeno), nebo vynuťte jednu stranu."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Τα προφίλ αυτού του λογαριασμού διαφέρουν από αυτή τη συσκευή. Συγχωνεύστε και τα δύο για να διατηρήσετε κάθε προφίλ (συνιστάται) ή επιβάλετε τη μία πλευρά."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הפרופילים בחשבון הזה שונים מאלה במכשיר הזה. מזג את שניהם כדי לשמור כל פרופיל (מומלץ), או כפה צד אחד."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne kontos profiler adskiller sig fra denne enhed. Flet begge for at beholde alle profiler (anbefales), eller gennemtving den ene side."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämän tilin profiilit eroavat tästä laitteesta. Yhdistä molemmat säilyttääksesi kaikki profiilit (suositeltava), tai pakota toinen puoli."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Profilene på denne kontoen er forskjellige fra denne enheten. Slå sammen begge for å beholde hver profil (anbefalt), eller tving fram én side."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Profilurile acestui cont diferă de cele de pe acest dispozitiv. Îmbină-le pe ambele pentru a păstra fiecare profil (recomandat) sau forțează una dintre părți."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ennek a fióknak a profiljai eltérnek ettől az eszköztől. Egyesítsd a kettőt minden profil megtartásához (ajánlott), vagy kényszerítsd az egyik oldalt."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Profil akaun ini berbeza daripada peranti ini. Gabungkan kedua-duanya untuk mengekalkan setiap profil (disyorkan), atau paksa satu pihak."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Naiiba ang mga profile ng account na ito sa device na ito. Pagsamahin ang dalawa para mapanatili ang bawat profile (inirerekomenda), o piliting isulong ang isang panig."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "نمایه‌های این حساب با این دستگاه متفاوت‌اند. هر دو را ادغام کنید تا همه نمایه‌ها حفظ شوند (توصیه‌شده)، یا یک طرف را اجبار کنید."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এই অ্যাকাউন্টের প্রোফাইল এই ডিভাইস থেকে আলাদা। প্রতিটি প্রোফাইল রাখতে উভয়টি মার্জ করুন (সুপারিশকৃত), অথবা একটি দিক জোর করুন।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இந்தக் கணக்கின் சுயவிவரங்கள் இந்தச் சாதனத்திலிருந்து வேறுபடுகின்றன. ஒவ்வொரு சுயவிவரத்தையும் வைத்திருக்க இரண்டையும் இணைக்கவும் (பரிந்துரைக்கப்படுகிறது), அல்லது ஒரு பக்கத்தைக் கட்டாயப்படுத்தவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ఈ ఖాతా ప్రొఫైల్‌లు ఈ పరికరం నుండి భిన్నంగా ఉన్నాయి. ప్రతి ప్రొఫైల్‌ను ఉంచుకోవడానికి రెండింటినీ విలీనం చేయండి (సిఫార్సు చేయబడింది), లేదా ఒక వైపును బలవంతం చేయండి."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "या खात्याची प्रोफाइल या डिव्हाइसपेक्षा वेगळी आहेत. प्रत्येक प्रोफाइल ठेवण्यासाठी दोन्ही विलीन करा (शिफारस केलेले), किंवा एका बाजूची सक्ती करा."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "આ account ની પ્રોફાઇલ આ ઉપકરણથી અલગ છે. દરેક પ્રોફાઇલ રાખવા બંનેને મર્જ કરો (ભલામણ કરેલ), અથવા એક બાજુ ફરજિયાત કરો."
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಈ ಖಾತೆಯ ಪ್ರೊಫೈಲ್‌ಗಳು ಈ ಸಾಧನದಿಂದ ಭಿನ್ನವಾಗಿವೆ. ಪ್ರತಿ ಪ್ರೊಫೈಲ್ ಅನ್ನು ಇರಿಸಿಕೊಳ್ಳಲು ಎರಡನ್ನೂ ವಿಲೀನಗೊಳಿಸಿ (ಶಿಫಾರಸು ಮಾಡಲಾಗಿದೆ), ಅಥವಾ ಒಂದು ಬದಿಯನ್ನು ಒತ್ತಾಯಿಸಿ."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "ഈ അക്കൗണ്ടിന്റെ പ്രൊഫൈലുകൾ ഈ ഉപകരണത്തിൽ നിന്ന് വ്യത്യാസപ്പെട്ടിരിക്കുന്നു. എല്ലാ പ്രൊഫൈലുകളും നിലനിർത്താൻ രണ്ടും ലയിപ്പിക്കുക (ശുപാർശ ചെയ്യുന്നു), അല്ലെങ്കിൽ ഒരു വശം നിർബന്ധമാക്കുക."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اس اکاؤنٹ کے پروفائلز اس ڈیوائس سے مختلف ہیں۔ ہر پروفائل رکھنے کے لیے دونوں کو ضم کریں (تجویز کردہ)، یا کسی ایک طرف پر مجبور کریں۔"
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Profily tohto účtu sa líšia od tohto zariadenia. Zlúčte oba, aby ste zachovali každý profil (odporúčané), alebo vynúťte jednu stranu."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Профилите на този акаунт се различават от това устройство. Обединете и двете, за да запазите всеки профил (препоръчително), или наложете една страна."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Profili ovog računa razlikuju se od ovog uređaja. Spojite oba kako biste zadržali svaki profil (preporučeno) ili nametnite jednu stranu."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Профили овог налога се разликују од овог уређаја. Споједините оба да задржите сваки профил (препоручено), или приморајте једну страну."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Profili tega računa se razlikujejo od te naprave. Združite oba, da ohranite vsak profil (priporočeno), ali prisilite eno stran."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Šios paskyros profiliai skiriasi nuo šio įrenginio. Sujunkite abu, kad išsaugotumėte kiekvieną profilį (rekomenduojama), arba priverstinai pasirinkite vieną pusę."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Šī konta profili atšķiras no šīs ierīces. Apvienojiet abus, lai paturētu katru profilu (ieteicams), vai piespiediet vienu pusi."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Selle konto profiilid erinevad selle seadme omadest. Ühenda mõlemad, et säilitada kõik profiilid (soovitatav), või sunni üks pool peale."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Els perfils d'aquest compte difereixen dels d'aquest dispositiu. Fusiona'ls tots dos per conservar cada perfil (recomanat), o força un dels costats."
          }
        },
        "gl": {
          "stringUnit": {
            "state": "translated",
            "value": "Os perfís desta conta difiren dos deste dispositivo. Combínaos para conservar todos os perfís (recomendado) ou forza un dos lados."
          }
        },
        "eu": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontu honen profilak gailu honetatik desberdinak dira. Batu biak profil guztiak mantentzeko (gomendatuta), edo behartu alde bat."
          }
        },
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Hierdie rekening se profiele verskil van hierdie toestel. Saamvoeg albei om elke profiel te behou (aanbeveel), of forseer een kant."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu hesabın profilləri bu cihazdan fərqlidir. Hər iki profili saxlamaq üçün birləşdirin (tövsiyə olunur) və ya bir tərəfi məcburi edin."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Profilet e kësaj llogarie ndryshojnë nga kjo pajisje. Bashkojini të dyja për të mbajtur çdo profil (rekomandohet), ose detyroni njërën anë."
          }
        },
        "is": {
          "stringUnit": {
            "state": "translated",
            "value": "Prófílar þessa reiknings eru ólíkir þessum tæki. Sameina báðar hliðar til að geyma alla prófíla (mælt með), eða þvinga annarri hlið."
          }
        },
        "mk": {
          "stringUnit": {
            "state": "translated",
            "value": "Профилите на оваа сметка се разликуваат од овој уред. Спојте ги двете за да ги задржите сите профили (препорачано) или принудете една страна."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Wasifu wa akaunti hii unatofautiana na kifaa hiki. Unganisha vyote ili kuweka kila wasifu (inayopendekezwa), au lazimisha upande mmoja."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Бұл тіркелгінің профильдері осы құрылғыдан өзгеше. Әрбір профильді сақтау үшін екеуін де біріктіріңіз (ұсынылады) немесе бір жақты таңдаңыз."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Այս հաշվի պրոֆիլները տարբերվում են այս սարքի պրոֆիլներից։ Միաձուլեք երկուսն էլ, որ պահեք բոլոր պրոֆիլները (խորհուրդ է տրվում), կամ ընտրեք մեկ կողմ։"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "translated",
            "value": "ამ ანგარიშის პროფილები განსხვავდება ამ მოწყობილობისგან. გაერთიანება ინახავს ყველა პროფილს (რეკომენდებულია), ან ძალით გაიმარჯვებს ერთ მხარეს."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਇਸ ਖਾਤੇ ਦੀਆਂ ਪ੍ਰੋਫ਼ਾਈਲਾਂ ਇਸ ਡਿਵਾਈਸ ਤੋਂ ਵੱਖਰੀਆਂ ਹਨ। ਹਰ ਪ੍ਰੋਫ਼ਾਈਲ ਰੱਖਣ ਲਈ ਦੋਵੇਂ ਮਿਲਾਓ (ਸਿਫਾਰਸ਼ਿਤ), ਜਾਂ ਇੱਕ ਪਾਸੇ ਨੂੰ ਲਾਜ਼ਮੀ ਕਰੋ।"
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "यस खाताका प्रोफाइलहरू यस उपकरणसँग भिन्न छन्। प्रत्येक प्रोफाइल राख्न दुबै मर्ज गर्नुहोस् (सिफारिस गरिन्छ), वा एक पक्षलाई जबर्जस्ती लागू गर्नुहोस्।"
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "ይህ መለያ መገለጫዎቹ ከዚህ መሳሪያ ጋር ይለያያሉ። ሁሉንም ለማቆየት ሁለቱን ዋህድ (የሚመከር)፣ ወይም አንዱን ጎን ብቻ ጠቀምት።"
          }
        },
        "km": {
          "stringUnit": {
            "state": "translated",
            "value": "ប្រវត្តិរូបរបស់គណនីនេះខុសពីឧបករណ៍នេះ។ បញ្ចូលគ្នាទាំងពីរ ដើម្បីរក្សាប្រវត្តិរូបទាំងអស់ (ត្រូវបានណែនាំ) ឬបង្ខំផ្នែកម្ខាង។"
          }
        }
      }
    },
    "This is shown only once. It is the only way back in if you forget your password and lose your devices. Store it somewhere safe.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Viene mostrato una sola volta. È l'unico modo per rientrare se dimentichi la password e perdi i tuoi dispositivi. Conservalo in un luogo sicuro."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto se muestra una sola vez. Es la única forma de volver a entrar si olvidas tu contraseña y pierdes tus dispositivos. Guárdalo en un lugar seguro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ceci n'est affiché qu'une seule fois. C'est le seul moyen de revenir si vous oubliez votre mot de passe et perdez vos appareils. Conservez-le en lieu sûr."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies wird nur einmal angezeigt. Es ist der einzige Weg zurück, falls du dein Passwort vergisst und deine Geräte verlierst. Bewahre es an einem sicheren Ort auf."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isto é exibido apenas uma vez. É a única forma de voltar a entrar caso esqueça sua senha e perca seus dispositivos. Guarde-o em um lugar seguro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これは一度だけ表示されます。パスワードを忘れてデバイスを失った場合に戻る唯一の方法です。安全な場所に保管してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 코드는 한 번만 표시됩니다. 비밀번호를 잊고 기기를 잃었을 때 다시 들어올 수 있는 유일한 방법입니다. 안전한 곳에 보관하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此内容仅显示一次。这是你忘记密码并丢失设备后唯一的找回方式。请将其存放在安全的地方。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это показывается только один раз. Это единственный способ вернуться, если вы забудете пароль и потеряете устройства. Храните его в надёжном месте."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह केवल एक बार दिखाया जाता है। यदि आप अपना पासवर्ड भूल जाते हैं और अपने डिवाइस खो देते हैं तो वापस आने का यही एकमात्र रास्ता है। इसे कहीं सुरक्षित रखें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يُعرَض هذا مرة واحدة فقط. إنه الطريقة الوحيدة للعودة إذا نسيت كلمة المرور وفقدت أجهزتك. خزّنه في مكان آمن."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu yalnızca bir kez gösterilir. Parolanızı unutur ve cihazlarınızı kaybederseniz geri dönmenin tek yolu budur. Güvenli bir yerde saklayın."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Isto é mostrado apenas uma vez. É a única forma de voltar a entrar se esquecer a palavra-passe e perder os dispositivos. Guarde-o num local seguro."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit wordt maar één keer getoond. Het is de enige manier om weer binnen te komen als je je wachtwoord vergeet en je apparaten kwijtraakt. Bewaar het op een veilige plek."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "To jest pokazane tylko raz. To jedyny sposób na odzyskanie dostępu, jeśli zapomnisz hasła i utracisz urządzenia. Przechowuj go w bezpiecznym miejscu."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Detta visas bara en gång. Det är enda sättet tillbaka in om du glömmer ditt lösenord och förlorar dina enheter. Förvara det på en säker plats."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此內容只會顯示一次。若你忘記密碼且失去裝置，這是唯一的回復途徑。請妥善保存在安全的地方。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini hanya ditampilkan sekali. Ini satu-satunya cara masuk kembali jika Anda lupa kata sandi dan kehilangan perangkat. Simpan di tempat yang aman."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "จะแสดงเพียงครั้งเดียวเท่านั้น เป็นทางเดียวที่จะกลับเข้าได้หากคุณลืมรหัสผ่านและสูญเสียอุปกรณ์ เก็บไว้ในที่ปลอดภัย"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mã này chỉ hiển thị một lần. Đây là cách duy nhất để vào lại nếu bạn quên mật khẩu và mất các thiết bị. Hãy cất giữ ở nơi an toàn."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Це показується лише раз. Це єдиний спосіб повернутися, якщо ви забудете пароль і втратите свої пристрої. Зберігайте його в надійному місці."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Toto se zobrazí jen jednou. Je to jediná cesta zpět, pokud zapomenete heslo a přijdete o svá zařízení. Uložte si jej na bezpečné místo."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αυτό εμφανίζεται μόνο μία φορά. Είναι ο μόνος τρόπος επανεισόδου αν ξεχάσετε τον κωδικό πρόσβασής σας και χάσετε τις συσκευές σας. Φυλάξτε το σε ασφαλές μέρος."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "זה מוצג פעם אחת בלבד. זו הדרך היחידה לחזור פנימה אם תשכח את הסיסמה ותאבד את המכשירים שלך. שמור אותו במקום בטוח."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette vises kun én gang. Det er den eneste vej tilbage, hvis du glemmer din adgangskode og mister dine enheder. Opbevar det et sikkert sted."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämä näytetään vain kerran. Se on ainoa tapa päästä takaisin, jos unohdat salasanasi ja menetät laitteesi. Säilytä se turvallisessa paikassa."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette vises bare én gang. Det er eneste vei inn igjen hvis du glemmer passordet og mister enhetene dine. Oppbevar det et trygt sted."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Acesta este afișat o singură dată. Este singura modalitate de a reintra dacă îți uiți parola și îți pierzi dispozitivele. Păstrează-l undeva în siguranță."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ez csak egyszer jelenik meg. Ez az egyetlen mód a visszajutásra, ha elfelejted a jelszavad és elveszíted az eszközeidet. Tárold biztonságos helyen."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini ditunjukkan hanya sekali. Ia satu-satunya jalan masuk semula jika anda terlupa kata laluan dan kehilangan peranti anda. Simpan di tempat yang selamat."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Ipinapakita lamang ito nang isang beses. Ito ang tanging paraan pabalik kung makakalimutan mo ang iyong password at mawawala ang iyong mga device. Itago ito sa ligtas na lugar."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "این فقط یک‌بار نشان داده می‌شود. این تنها راه بازگشت است اگر رمز عبور خود را فراموش کنید و دستگاه‌هایتان را از دست بدهید. آن را جایی امن نگه دارید."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এটি শুধু একবারই দেখানো হয়। আপনি পাসওয়ার্ড ভুলে গেলে এবং আপনার ডিভাইস হারালে ফিরে আসার এটিই একমাত্র উপায়। এটি নিরাপদ কোথাও সংরক্ষণ করুন।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இது ஒரு முறை மட்டுமே காட்டப்படும். உங்கள் கடவுச்சொல்லை மறந்து உங்கள் சாதனங்களை இழந்தால் மீண்டும் உள்ளே வர இதுவே ஒரே வழி. பாதுகாப்பான இடத்தில் வைக்கவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ఇది ఒక్కసారి మాత్రమే చూపబడుతుంది. మీరు మీ పాస్‌వర్డ్ మర్చిపోయి మీ పరికరాలను కోల్పోతే తిరిగి లోపలికి వచ్చే ఏకైక మార్గం ఇదే. దీన్ని సురక్షితమైన చోట భద్రపరచండి."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "हे फक्त एकदाच दाखवले जाते. तुम्ही तुमचा पासवर्ड विसरलात आणि तुमची डिव्हाइस गमावलीत तर परत येण्याचा हाच एकमेव मार्ग आहे. ते सुरक्षित ठिकाणी जतन करा."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "આ ફક્ત એક જ વાર બતાવાય છે. જો તમે તમારો પાસવર્ડ ભૂલી જાઓ અને તમારા ઉપકરણો ગુમાવો તો અંદર પાછા આવવાનો આ એકમાત્ર માર્ગ છે. તેને ક્યાંક સલામત રાખો."
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಇದನ್ನು ಒಮ್ಮೆ ಮಾತ್ರ ತೋರಿಸಲಾಗುತ್ತದೆ. ನೀವು ನಿಮ್ಮ ಪಾಸ್‌ವರ್ಡ್ ಮರೆತು ನಿಮ್ಮ ಸಾಧನಗಳನ್ನು ಕಳೆದುಕೊಂಡರೆ ಮರಳಿ ಪ್ರವೇಶಿಸಲು ಇದೇ ಏಕೈಕ ಮಾರ್ಗ. ಇದನ್ನು ಸುರಕ್ಷಿತ ಸ್ಥಳದಲ್ಲಿ ಇರಿಸಿ."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "ഇത് ഒരിക്കൽ മാത്രമേ കാണിക്കൂ. നിങ്ങളുടെ പാസ്‌വേഡ് മറക്കുകയും നിങ്ങളുടെ ഉപകരണങ്ങൾ നഷ്ടപ്പെടുകയും ചെയ്താൽ തിരികെ വരാനുള്ള ഏക മാർഗ്ഗമാണിത്. ഇത് സുരക്ഷിതമായ ഒരിടത്ത് സൂക്ഷിക്കുക."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہ صرف ایک بار دکھایا جاتا ہے۔ اگر آپ اپنا پاس ورڈ بھول جائیں اور اپنی ڈیوائسز کھو دیں تو واپس آنے کا یہی واحد راستہ ہے۔ اسے کسی محفوظ جگہ رکھیں۔"
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Toto sa zobrazí len raz. Je to jediná cesta späť, ak zabudnete heslo a stratíte zariadenia. Uložte si ho na bezpečné miesto."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Това се показва само веднъж. То е единственият начин да влезете отново, ако забравите паролата си и загубите устройствата си. Съхранявайте го на сигурно място."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ovo se prikazuje samo jednom. To je jedini način povratka ako zaboravite lozinku i izgubite uređaje. Pohranite ga na sigurno mjesto."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ово се приказује само једном. То је једини начин да се вратите ако заборавите лозинку и изгубите уређаје. Сачувајте га на безбедном месту."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "To je prikazano samo enkrat. Je edini način za vrnitev, če pozabite geslo in izgubite naprave. Shranite jo na varno mesto."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Tai rodoma tik vieną kartą. Tai vienintelis būdas grįžti, jei pamiršite slaptažodį ir prarasite įrenginius. Laikykite jį saugioje vietoje."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tas tiek rādīts tikai vienreiz. Tas ir vienīgais veids, kā atgriezties, ja aizmirstat paroli un pazaudējat ierīces. Glabājiet to drošā vietā."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Seda kuvatakse ainult ühe korra. See on ainus viis tagasi pääseda, kui unustad parooli ja kaotad oma seadmed. Hoia seda turvalises kohas."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Això es mostra una sola vegada. És l'única manera de recuperar l'accés si oblides la contrasenya i perds els dispositius. Desa'l en un lloc segur."
          }
        },
        "gl": {
          "stringUnit": {
            "state": "translated",
            "value": "Isto móstrase só unha vez. É a única forma de recuperar o acceso se esqueces o contrasinal e perdes os dispositivos. Gárdao nun lugar seguro."
          }
        },
        "eu": {
          "stringUnit": {
            "state": "translated",
            "value": "Hau behin soilik erakusten da. Pasahitza ahaztu eta zure gailuak galtzen badituzu itzultzeko modu bakarra da. Gorde leku seguru batean."
          }
        },
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit word slegs een keer gewys. Dit is die enigste manier terug as jy jou wagwoord vergeet en jou toestelle verloor. Stoor dit êrens veilig."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu yalnız bir dəfə göstərilir. Şifrənizi unutsanız və cihazlarınızı itirsəniz geri dönməyin yeganə yoludur. Onu təhlükəsiz bir yerdə saxlayın."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Kjo tregohet vetëm një herë. Është mënyra e vetme e kthimit nëse harroni fjalëkalimin dhe humbisni pajisjet tuaja. Ruajeni diku të sigurt."
          }
        },
        "is": {
          "stringUnit": {
            "state": "translated",
            "value": "Þetta er aðeins sýnt einu sinni. Þetta er eina leiðin aftur inn ef þú gleymir lykilorðinu og missir tækin þín. Geymdu það á öruggum stað."
          }
        },
        "mk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ова се прикажува само еднаш. Тоа е единствениот начин за пристап ако ја заборавите лозинката и ги изгубите уредите. Зачувајте го на безбедно место."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Hii inaonyeshwa mara moja tu. Ndiyo njia pekee ya kurudi ndani ikiwa utasahau nenosiri lako na kupoteza vifaa vyako. Ihifadhi mahali salama."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Бұл тек бір рет көрсетіледі. Егер құпия сөзіңізді ұмытып, құрылғыларыңызды жоғалтсаңыз, бұл — жалғыз кіру жолы. Оны қауіпсіз жерде сақтаңыз."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Սա ցուցադրվում է միայն մեկ անգամ։ Եթե մոռանաք ձեր գաղտնաբառը և կորցնեք ձեր սարքերը, վերականգնման միակ ճանապարհն այն է։ Պահեք ապահով վայրում։"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "translated",
            "value": "ეს ნაჩვენებია მხოლოდ ერთხელ. ეს არის ერთადერთი გზა შიგნით, თუ პაროლი დაგავიწყდათ და მოწყობილობები დაკარგეთ. შეინახეთ უსაფრთხო ადგილას."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਇਹ ਸਿਰਫ਼ ਇੱਕ ਵਾਰ ਦਿਖਾਇਆ ਜਾਂਦਾ ਹੈ। ਜੇ ਤੁਸੀਂ ਆਪਣਾ ਪਾਸਵਰਡ ਭੁੱਲ ਜਾਓ ਅਤੇ ਆਪਣੇ ਡਿਵਾਈਸ ਗੁਆ ਦਿਓ ਤਾਂ ਵਾਪਸ ਅੰਦਰ ਆਉਣ ਦਾ ਇਹ ਇੱਕੋ ਰਾਹ ਹੈ। ਇਸਨੂੰ ਕਿਸੇ ਸੁਰੱਖਿਅਤ ਜਗ੍ਹਾ ਸਟੋਰ ਕਰੋ।"
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "यो एकपटक मात्र देखाइन्छ। यदि तपाईं आफ्नो पासवर्ड बिर्सनुभयो र उपकरणहरू गुमाउनुभयो भने यही एकमात्र फिर्ती बाटो हो। यसलाई कतै सुरक्षित राख्नुहोस्।"
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "ይህ አንዴ ብቻ ይታያሉ። የይለፍ ቃሉን ከረሱ እና መሳሪያዎቹን ከጣሉ ወደ ውስጥ ለመመለስ ብቸኛው መንገድ ነው። ደህና ቦታ ያስቀምጡ።"
          }
        },
        "km": {
          "stringUnit": {
            "state": "translated",
            "value": "វត្ថុនេះត្រូវបានបង្ហាញតែម្តងប៉ុណ្ណោះ។ វាជាមធ្យោបាយតែមួយដើម្បីចូលឡើងវិញ ប្រសិនបើអ្នកភ្លេចពាក្យសម្ងាត់ ហើយបាត់ឧបករណ៍របស់អ្នក។ រក្សាទុកវានៅកន្លែងមានសុវត្ថិភាព។"
          }
        }
      }
    },
