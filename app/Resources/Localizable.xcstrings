        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Əlavə manifest URL-lərini hər sətirdə biri olacaq şəkildə yapışdırın, sonra hamısını bir addımda quraşdırın."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Ngjisni URL-të e manifestit të shtesave, një për rresht, pastaj instalojini të gjitha njëherësh."
