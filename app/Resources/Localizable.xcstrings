    "Use the server embedded on this device, or point VortX at a remote / dedicated Stremio server (for example one you run at home).": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa il server integrato in questo dispositivo, oppure punta VortX a un server Stremio remoto / dedicato (ad esempio uno che gestisci a casa)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa el servidor integrado en este dispositivo, o apunta VortX a un servidor Stremio remoto / dedicado (por ejemplo uno que ejecutes en casa)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez le serveur intégré à cet appareil, ou pointez VortX vers un serveur Stremio distant / dédié (par exemple un que vous hébergez chez vous)."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwende den auf diesem Gerät eingebetteten Server oder richte VortX auf einen entfernten / dedizierten Stremio-Server aus (zum Beispiel einen, den du zu Hause betreibst)."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use o servidor integrado neste dispositivo ou aponte a VortX para um servidor Stremio remoto / dedicado (por exemplo, um que você rode em casa)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このデバイスに内蔵されたサーバーを使用するか、VortX をリモート／専用の Stremio サーバー（例えば自宅で運用しているもの）に向けます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 기기에 내장된 서버를 사용하거나, VortX를 원격/전용 Stremio 서버(예: 집에서 직접 운영하는 서버)로 연결하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用本设备上内置的服务器，或让 VortX 指向远程／专用的 Stremio 服务器（例如你在家运行的服务器）。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте сервер, встроенный в это устройство, или укажите VortX удалённый / выделенный сервер Stremio (например, тот, что вы запускаете дома)."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस डिवाइस पर एम्बेडेड सर्वर का उपयोग करें, या VortX को किसी रिमोट / समर्पित Stremio सर्वर की ओर इंगित करें (उदाहरण के लिए जिसे आप घर पर चलाते हों)।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم الخادم المدمج على هذا الجهاز، أو وجّه VortX إلى خادم Stremio بعيد / مخصّص (على سبيل المثال خادم تشغّله في منزلك)."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu cihazda yerleşik sunucuyu kullanın veya VortX'i uzak / özel bir Stremio sunucusuna yönlendirin (örneğin evinizde çalıştırdığınız bir tane)."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Use o servidor incorporado neste dispositivo ou aponte a VortX para um servidor Stremio remoto / dedicado (por exemplo, um que execute em casa)."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gebruik de server die op dit apparaat is ingebouwd, of wijs VortX naar een externe / aparte Stremio-server (bijvoorbeeld een die je thuis draait)."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Użyj serwera wbudowanego na tym urządzeniu lub wskaż VortX zdalny / dedykowany serwer Stremio (na przykład taki, który prowadzisz w domu)."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Använd servern som är inbäddad på den här enheten, eller rikta VortX mot en fjärr-/dedikerad Stremio-server (till exempel en du kör hemma)."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用此裝置上的內嵌伺服器，或讓 VortX 指向遠端／專用的 Stremio 伺服器（例如你在家自架的伺服器）。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Gunakan server yang tertanam di perangkat ini, atau arahkan VortX ke server Stremio jarak jauh / khusus (misalnya yang Anda jalankan di rumah)."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้เซิร์ฟเวอร์ที่ฝังอยู่บนอุปกรณ์นี้ หรือชี้ VortX ไปยังเซิร์ฟเวอร์ Stremio ระยะไกล/เฉพาะ (เช่น เซิร์ฟเวอร์ที่คุณรันที่บ้าน)"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Dùng máy chủ được nhúng trên thiết bị này, hoặc trỏ VortX tới một máy chủ Stremio từ xa / chuyên dụng (ví dụ máy chủ bạn tự chạy ở nhà)."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Використовуйте сервер, вбудований у цей пристрій, або спрямуйте VortX на віддалений / виділений сервер Stremio (наприклад, той, що ви тримаєте вдома)."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Použijte server vestavěný v tomto zařízení, nebo nasměrujte VortX na vzdálený / vyhrazený server Stremio (například ten, který provozujete doma)."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Χρησιμοποιήστε τον διακομιστή που είναι ενσωματωμένος σε αυτή τη συσκευή ή κατευθύνετε το VortX σε έναν απομακρυσμένο / αποκλειστικό διακομιστή Stremio (για παράδειγμα έναν που τρέχετε στο σπίτι)."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "השתמש בשרת המוטמע במכשיר הזה, או הפנה את VortX לשרת Stremio מרוחק / ייעודי (לדוגמה כזה שאתה מפעיל בבית)."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Brug serveren indbygget på denne enhed, eller peg VortX mod en ekstern/dedikeret Stremio-server (for eksempel en, du kører hjemme)."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Käytä tällä laitteella sisäänrakennettua palvelinta tai osoita VortX etä- tai erilliseen Stremio-palvelimeen (esimerkiksi kotonasi pyörivään)."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Bruk serveren som er innebygd på denne enheten, eller pek VortX mot en ekstern / dedikert Stremio-server (for eksempel en du kjører hjemme)."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Folosește serverul încorporat pe acest dispozitiv sau direcționează VortX către un server Stremio la distanță / dedicat (de exemplu unul pe care îl rulezi acasă)."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Használd az ezen az eszközön beépített szervert, vagy irányítsd a VortX-et egy távoli / dedikált Stremio-szerverre (például egy otthon futtatottra)."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Guna pelayan terbenam pada peranti ini, atau arahkan VortX ke pelayan Stremio jauh / khusus (contohnya yang anda jalankan di rumah)."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Gamitin ang server na naka-embed sa device na ito, o ituro ang VortX sa isang remote / dedicated na Stremio server (halimbawa isang pinapatakbo mo sa bahay)."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "از سرور تعبیه‌شده روی این دستگاه استفاده کنید، یا VortX را به یک سرور Stremio راه دور / اختصاصی متصل کنید (برای مثال سروری که در خانه اجرا می‌کنید)."
          }
        }
      }
    },
