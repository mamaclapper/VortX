        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ はそのプロファイルからのみ編集できます"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@은(는) 해당 프로필에서만 편집할 수 있습니다"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 只能从该配置文件中编辑"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ можно редактировать только из этого профиля"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ को केवल उसी प्रोफ़ाइल से संपादित किया जा सकता है"
          }
        },
        "ar": {
          "stringUnit": {
