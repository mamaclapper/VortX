    },
    "None of your %@ add-on%@ returned a playable source for this title.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "None of your %1$@ add-on%2$@ returned a playable source for this title."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessuno dei tuoi %@ componente aggiuntivo%@ ha restituito una sorgente riproducibile per questo titolo."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ninguno de tus %@ complemento%@ devolvió una fuente reproducible para este título."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun de vos %@ add-on%@ n'a renvoyé de source lisible pour ce titre."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keines deiner %@ Add-on%@ hat für diesen Titel eine abspielbare Quelle geliefert."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhum dos seus %@ complemento%@ retornou uma fonte reproduzível para este título."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 個のアドオン%@ のいずれも、このタイトルの再生可能なソースを返しませんでした。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 부가 기능 %@개 중 어느 것도 이 작품에 대해 재생 가능한 소스를 반환하지 않았습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的 %@ 个附加组件%@ 均未返回此影片的可播放来源。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ни одно из ваших %@ дополнени%@ не вернуло воспроизводимый источник для этого тайтла."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके %@ ऐड-ऑन%@ में से किसी ने भी इस टाइटल के लिए चलने योग्य स्रोत नहीं लौटाया।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم تُرجع أيٌّ من إضافاتك %@%@ مصدرًا قابلًا للتشغيل لهذا العنوان."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ eklentinizin%@ hiçbiri bu içerik için oynatılabilir bir kaynak döndürmedi."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhum dos seus %@ add-on%@ devolveu uma fonte reproduzível para este título."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Geen van je %@ add-on%@ leverde een afspeelbare bron voor deze titel."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Żaden z Twoich %@ dodatk%@ nie zwrócił odtwarzalnego źródła dla tego tytułu."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Inget av dina %@ tillägg%@ returnerade en spelbar källa för den här titeln."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的 %@ 外掛%@均未為此片名傳回可播放的來源。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tidak ada dari %@ add-on%@ Anda yang mengembalikan sumber yang dapat diputar untuk judul ini."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ไม่มีแอดออน %@ รายการ%@ ของคุณที่พบแหล่งที่เล่นได้สำหรับเรื่องนี้"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Không có tiện ích bổ sung %@ nào%@ trả về nguồn có thể phát cho tựa đề này."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Жоден із ваших додатків (%@)%@ не повернув придатного для відтворення джерела для цього тайтлу."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Žádný z vašich %@ doplňků%@ nevrátil pro tento titul přehratelný zdroj."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Κανένα από τα %@ πρόσθετα%@ σας δεν επέστρεψε αναπαραγώγιμη πηγή για αυτόν τον τίτλο."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "אף אחת מ-%@ ההרחבות%@ שלך לא החזירה מקור ניתן להשמעה לכותר זה."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen af dine %@ tilføjelser%@ returnerede en afspilbar kilde til denne titel."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Yksikään %@ lisäosistasi%@ ei palauttanut toistettavaa lähdettä tälle nimikkeelle."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen av %@ tillegg%@ ga en spillbar kilde for denne tittelen."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Niciunul dintre cele %@ add-on%@ ale tale nu a returnat o sursă redabilă pentru acest titlu."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A(z) %@ kiegészítőd%@ egyike sem talált lejátszható forrást ehhez a címhez."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiada satu pun daripada %@ tambahan%@ anda memulangkan sumber yang boleh dimainkan untuk tajuk ini."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Wala sa iyong %@ add-on%@ ang nagbalik ng napa-play na source para sa titulong ito."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "هیچ‌کدام از %@ افزونه%@ شما منبع قابل‌پخشی برای این عنوان برنگرداندند."
          }
        }
      }
    },
