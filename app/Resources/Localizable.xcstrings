    "Scan with your phone to open this stream there  ·  Press Back to dismiss": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scansiona col telefono per aprire questa sorgente lì  ·  Premi Indietro per chiudere"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Escanea con tu móvil para abrir esta fuente allí  ·  Pulsa Atrás para descartar"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Scannez avec votre téléphone pour ouvrir ce stream là-bas  ·  Appuyez sur Retour pour fermer"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mit deinem Telefon scannen, um diesen Stream dort zu öffnen  ·  Zum Schließen Zurück drücken"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Leia com seu celular para abrir este stream lá  ·  Pressione Voltar para dispensar"
