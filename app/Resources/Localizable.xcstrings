    "Makes every screen's text larger or smaller. Changes apply instantly.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rende il testo di ogni schermata più grande o più piccolo. Le modifiche si applicano subito."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hace el texto de cada pantalla más grande o más pequeño. Los cambios se aplican al instante."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Agrandit ou réduit le texte de tous les écrans. Les changements s'appliquent immédiatement."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Macht den Text auf jedem Bildschirm größer oder kleiner. Änderungen werden sofort übernommen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Deixa o texto de cada tela maior ou menor. As alterações são aplicadas instantaneamente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべての画面の文字を大きくまたは小さくします。変更はすぐに適用されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모든 화면의 텍스트를 더 크거나 작게 만듭니다. 변경 사항은 즉시 적용됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "让每个屏幕的文字变大或变小。更改即时生效。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Делает текст на всех экранах крупнее или мельче. Изменения применяются мгновенно."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हर स्क्रीन का टेक्स्ट बड़ा या छोटा करता है। बदलाव तुरंत लागू होते हैं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يكبّر نص كل شاشة أو يصغّره. تُطبَّق التغييرات فورًا."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Her ekranın metnini büyütür veya küçültür. Değişiklikler anında uygulanır."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Torna o texto de todos os ecrãs maior ou menor. As alterações aplicam-se de imediato."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Maakt de tekst op elk scherm groter of kleiner. Wijzigingen worden meteen toegepast."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Powiększa lub pomniejsza tekst na każdym ekranie. Zmiany są stosowane natychmiast."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Gör texten på varje skärm större eller mindre. Ändringar tillämpas direkt."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "讓每個畫面的文字變大或變小。變更會立即套用。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Membuat teks setiap layar lebih besar atau lebih kecil. Perubahan berlaku seketika."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ทำให้ข้อความทุกหน้าจอใหญ่ขึ้นหรือเล็กลง การเปลี่ยนแปลงจะมีผลทันที"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Làm cho chữ trên mọi màn hình to hơn hoặc nhỏ hơn. Thay đổi được áp dụng ngay lập tức."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Робить текст на кожному екрані більшим або меншим. Зміни застосовуються миттєво."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zvětší nebo zmenší text na všech obrazovkách. Změny se projeví okamžitě."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Κάνει το κείμενο κάθε οθόνης μεγαλύτερο ή μικρότερο. Οι αλλαγές εφαρμόζονται άμεσα."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "מגדיל או מקטין את הטקסט בכל מסך. השינויים חלים מיד."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Gør teksten på alle skærme større eller mindre. Ændringer træder i kraft med det samme."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Suurentaa tai pienentää jokaisen näytön tekstiä. Muutokset tulevat voimaan välittömästi."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Gjør teksten på alle skjermer større eller mindre. Endringer trer i kraft umiddelbart."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Mărește sau micșorează textul din fiecare ecran. Modificările se aplică instant."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Minden képernyőn nagyobbá vagy kisebbé teszi a szöveget. A változtatások azonnal érvénybe lépnek."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Menjadikan teks setiap skrin lebih besar atau lebih kecil. Perubahan digunakan serta-merta."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Pinalalaki o pinaliliit ang teksto sa bawat screen. Agad inilalapat ang mga pagbabago."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "متن هر صفحه را بزرگ‌تر یا کوچک‌تر می‌کند. تغییرات بلافاصله اعمال می‌شوند."
          }
        }
      }
    },
