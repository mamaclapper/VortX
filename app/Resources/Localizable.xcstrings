        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "ምረጥ = ሌላ ምንጭ ምረጥ    ·    አጫውት/አቁም = ዳግም ሞክር    ·    ምናሌ = ወደ ኋላ"
          }
        },
        "km": {
          "stringUnit": {
            "state": "translated",
            "value": "Select = ជ្រើសប្រភពផ្សេង    ·    Play/Pause = ព្យាយាមឡើងវិញ    ·    Menu = ត្រឡប់ក្រោយ"
          }
        }
      }
    },
    "Select a profile to edit it. Each profile keeps its own look, languages, PIN, and optionally its own Stremio account. A profile with a PIN asks for it before it can be edited.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Seleziona un profilo per modificarlo. Ogni profilo mantiene il proprio aspetto, le lingue, il PIN e, facoltativamente, il proprio account Stremio. Un profilo con PIN lo richiede prima di poter essere modificato."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecciona un perfil para editarlo. Cada perfil mantiene su propio aspecto, idiomas, PIN y, opcionalmente, su propia cuenta Stremio. Un perfil con PIN lo pide antes de poder editarse."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sélectionnez un profil pour le modifier. Chaque profil conserve sa propre apparence, ses langues, son code PIN et, en option, son propre compte Stremio. Un profil protégé par un code PIN le demande avant toute modification."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle ein Profil zum Bearbeiten. Jedes Profil behält sein eigenes Aussehen, seine Sprachen, seine PIN und optional sein eigenes Stremio-Konto. Ein Profil mit PIN verlangt diese, bevor es bearbeitet werden kann."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecione um perfil para editá-lo. Cada perfil mantém a própria aparência, idiomas, PIN e, opcionalmente, a própria conta Stremio. Um perfil com PIN o solicita antes de poder ser editado."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "編集するプロファイルを選択してください。各プロファイルは独自の外観、言語、PIN、そして任意で独自の Stremio アカウントを保持します。PIN が設定されたプロファイルは、編集前に PIN の入力を求めます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "편집할 프로필을 선택하세요. 각 프로필은 고유한 모양, 언어, PIN, 그리고 선택적으로 자체 Stremio 계정을 유지합니다. PIN이 설정된 프로필은 편집하기 전에 PIN을 요구합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择一个配置文件进行编辑。每个配置文件保留它自己的外观、语言、PIN，以及可选的它自己的 Stremio 账户。设置了 PIN 的配置文件在被编辑前会要求输入 PIN。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите профиль, чтобы изменить его. У каждого профиля свой внешний вид, языки, PIN и, по желанию, свой аккаунт Stremio. Профиль с PIN запросит его перед редактированием."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "संपादित करने के लिए कोई प्रोफ़ाइल चुनें। हर प्रोफ़ाइल अपना खुद का रूप, भाषाएँ, PIN और वैकल्पिक रूप से अपना खुद का Stremio खाता रखती है। PIN वाली प्रोफ़ाइल संपादित होने से पहले उसे माँगती है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر ملفًا شخصيًا لتعديله. يحتفظ كل ملف شخصي بمظهره ولغاته ورمز PIN الخاص به، واختياريًا بحساب Stremio الخاص به. يطلب الملف الشخصي ذو رمز PIN إدخاله قبل أن يمكن تعديله."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Düzenlemek için bir profil seçin. Her profil kendi görünümünü, dillerini, PIN'ini ve isteğe bağlı olarak kendi Stremio hesabını tutar. PIN'i olan bir profil, düzenlenmeden önce onu sorar."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecione um perfil para o editar. Cada perfil mantém o seu próprio aspeto, idiomas, PIN e, opcionalmente, a sua própria conta Stremio. Um perfil com PIN pede-o antes de poder ser editado."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecteer een profiel om het te bewerken. Elk profiel houdt zijn eigen uiterlijk, talen, pincode en eventueel zijn eigen Stremio-account bij. Een profiel met een pincode vraagt erom voordat het bewerkt kan worden."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz profil, aby go edytować. Każdy profil zachowuje własny wygląd, języki, PIN i opcjonalnie własne konto Stremio. Profil z PIN-em poprosi o niego przed edycją."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Välj en profil för att redigera den. Varje profil behåller sitt eget utseende, sina språk, sin PIN och valfritt sitt eget Stremio-konto. En profil med PIN ber om den innan den kan redigeras."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選取一個設定檔進行編輯。每個設定檔都保有自己的外觀、語言、PIN，並可選擇連結自己的 Stremio 帳號。設有 PIN 的設定檔在編輯前會要求輸入 PIN。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih profil untuk mengeditnya. Setiap profil memiliki tampilan, bahasa, PIN, dan secara opsional akun Stremio-nya sendiri. Profil dengan PIN akan memintanya sebelum dapat diedit."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เลือกโปรไฟล์เพื่อแก้ไข แต่ละโปรไฟล์เก็บรูปลักษณ์ ภาษา PIN และบัญชี Stremio ของตัวเองได้ตามต้องการ โปรไฟล์ที่มี PIN จะถามรหัสก่อนจึงจะแก้ไขได้"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chọn một hồ sơ để chỉnh sửa. Mỗi hồ sơ giữ giao diện, ngôn ngữ, PIN riêng và tùy chọn tài khoản Stremio riêng. Hồ sơ có PIN sẽ yêu cầu nhập PIN trước khi có thể chỉnh sửa."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Виберіть профіль, щоб редагувати його. Кожен профіль зберігає власний вигляд, мови, PIN і за бажанням власний акаунт Stremio. Профіль із PIN запитує його перед редагуванням."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyberte profil, který chcete upravit. Každý profil si uchovává vlastní vzhled, jazyky, PIN a volitelně vlastní účet Stremio. Profil s PINem o něj požádá před úpravou."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Επιλέξτε ένα προφίλ για να το επεξεργαστείτε. Κάθε προφίλ διατηρεί τη δική του εμφάνιση, γλώσσες, PIN και προαιρετικά τον δικό του λογαριασμό Stremio. Ένα προφίλ με PIN το ζητά πριν μπορέσει να επεξεργαστεί."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "בחר פרופיל כדי לערוך אותו. כל פרופיל שומר מראה, שפות, PIN משלו, ואופציונלית חשבון Stremio משלו. פרופיל עם PIN מבקש אותו לפני שניתן לערוך אותו."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vælg en profil for at redigere den. Hver profil beholder sit eget udseende, sprog, PIN og eventuelt sin egen Stremio-konto. En profil med en PIN beder om den, før den kan redigeres."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Valitse profiili muokataksesi sitä. Jokainen profiili säilyttää oman ulkoasunsa, kielensä, PIN-koodinsa ja valinnaisesti oman Stremio-tilinsä. PIN-koodillinen profiili kysyy sitä ennen kuin sitä voi muokata."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Velg en profil for å redigere den. Hver profil beholder sitt eget utseende, språk, PIN og eventuelt sin egen Stremio-konto. En profil med PIN spør etter den før den kan redigeres."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Selectează un profil pentru a-l edita. Fiecare profil își păstrează propriul aspect, limbi, PIN și, opțional, propriul cont Stremio. Un profil cu PIN îl cere înainte de a putea fi editat."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Válassz egy profilt a szerkesztéséhez. Minden profil saját megjelenést, nyelveket, PIN-kódot és igény szerint saját Stremio-fiókot tart. A PIN-kóddal védett profil a szerkesztés előtt kéri azt."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih profil untuk menyuntingnya. Setiap profil mengekalkan rupa, bahasa, PIN, dan secara pilihan akaun Stremio tersendiri. Profil dengan PIN memintanya sebelum boleh disunting."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Pumili ng profile para i-edit ito. Ang bawat profile ay may sarili nitong hitsura, mga wika, PIN, at opsyonal na sarili nitong Stremio account. Ang isang profile na may PIN ay humihingi nito bago ito ma-edit."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "نمایه‌ای را برای ویرایش انتخاب کنید. هر نمایه ظاهر، زبان‌ها، PIN و در صورت تمایل حساب Stremio خاص خود را نگه می‌دارد. نمایه‌ای که PIN دارد، قبل از اینکه بتوان آن را ویرایش کرد، آن را می‌خواهد."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সম্পাদনা করতে একটি প্রোফাইল নির্বাচন করুন। প্রতিটি প্রোফাইল নিজের চেহারা, ভাষা, PIN এবং ঐচ্ছিকভাবে নিজের Stremio অ্যাকাউন্ট রাখে। PIN যুক্ত একটি প্রোফাইল সম্পাদনার আগে সেটি জানতে চায়।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "திருத்த ஒரு சுயவிவரத்தைத் தேர்ந்தெடுக்கவும். ஒவ்வொரு சுயவிவரமும் தனது சொந்தத் தோற்றம், மொழிகள், PIN மற்றும் விருப்பப்பட்டால் தனது சொந்த Stremio கணக்கை வைத்திருக்கும். PIN கொண்ட சுயவிவரம் திருத்தும் முன் அதைக் கேட்கும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ఎడిట్ చేయడానికి ఒక ప్రొఫైల్‌ను ఎంచుకోండి. ప్రతి ప్రొఫైల్ దాని స్వంత రూపం, భాషలు, PIN, మరియు ఐచ్ఛికంగా దాని స్వంత Stremio ఖాతాను ఉంచుకుంటుంది. PIN ఉన్న ప్రొఫైల్‌ను ఎడిట్ చేయడానికి ముందు అది PIN అడుగుతుంది."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "संपादित करण्यासाठी एक प्रोफाइल निवडा. प्रत्येक प्रोफाइल स्वतःचा देखावा, भाषा, PIN आणि पर्यायाने स्वतःचे Stremio खाते ठेवते. PIN असलेली प्रोफाइल संपादित करण्यापूर्वी तो विचारते."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "સંપાદિત કરવા પ્રોફાઇલ પસંદ કરો. દરેક પ્રોફાઇલ તેનો પોતાનો દેખાવ, ભાષાઓ, PIN અને વૈકલ્પિક રીતે તેનું પોતાનું Stremio account રાખે છે. PIN ધરાવતી પ્રોફાઇલ સંપાદિત થાય તે પહેલાં તે માગે છે."
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಸಂಪಾದಿಸಲು ಒಂದು ಪ್ರೊಫೈಲ್ ಆಯ್ಕೆಮಾಡಿ. ಪ್ರತಿ ಪ್ರೊಫೈಲ್ ತನ್ನದೇ ಆದ ನೋಟ, ಭಾಷೆಗಳು, PIN ಮತ್ತು ಐಚ್ಛಿಕವಾಗಿ ತನ್ನದೇ Stremio ಖಾತೆಯನ್ನು ಇರಿಸಿಕೊಳ್ಳುತ್ತದೆ. PIN ಹೊಂದಿರುವ ಪ್ರೊಫೈಲ್ ಅನ್ನು ಸಂಪಾದಿಸುವ ಮೊದಲು ಅದನ್ನು ಕೇಳುತ್ತದೆ."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "എഡിറ്റ് ചെയ്യാൻ ഒരു പ്രൊഫൈൽ തിരഞ്ഞെടുക്കുക. ഓരോ പ്രൊഫൈലും അതിന്റേതായ രൂപം, ഭാഷകൾ, PIN, ഓപ്ഷണലായി അതിന്റേതായ Stremio അക്കൗണ്ട് എന്നിവ നിലനിർത്തുന്നു. PIN ഉള്ള ഒരു പ്രൊഫൈൽ എഡിറ്റ് ചെയ്യുന്നതിന് മുമ്പ് അത് ചോദിക്കുന്നു."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ترمیم کرنے کے لیے کوئی پروفائل منتخب کریں۔ ہر پروفائل اپنی الگ شکل، زبانیں، PIN، اور اختیاری طور پر اپنا Stremio اکاؤنٹ رکھتا ہے۔ PIN والا پروفائل ترمیم سے پہلے اسے طلب کرتا ہے۔"
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyberte profil na jeho úpravu. Každý profil si zachováva vlastný vzhľad, jazyky, PIN a voliteľne vlastný účet Stremio. Profil s PIN-om si ho pred úpravou vyžiada."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Изберете профил, за да го редактирате. Всеки профил пази собствения си облик, езици, PIN и по избор собствен Stremio акаунт. Профил с PIN го изисква, преди да може да бъде редактиран."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Odaberite profil za uređivanje. Svaki profil zadržava vlastiti izgled, jezike, PIN i opcionalno vlastiti Stremio račun. Profil s PIN-om zatraži ga prije nego što se može urediti."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Изаберите профил да бисте га уредили. Сваки профил задржава сопствени изглед, језике, PIN и опционо сопствени Stremio налог. Профил са PIN-ом га тражи пре него што може да се уређује."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Izberite profil za urejanje. Vsak profil ima svoj videz, jezike, PIN in po izbiri svoj račun Stremio. Profil s PIN-om ga zahteva, preden ga je mogoče urejati."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Pasirinkite profilį, kad jį redaguotumėte. Kiekvienas profilis turi savo išvaizdą, kalbas, PIN kodą ir, jei norite, savo Stremio paskyrą. Profilis su PIN kodu prašo jo prieš pradedant redaguoti."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Atlasiet profilu, lai to rediģētu. Katrs profils uztur savu izskatu, valodas, PIN un, ja vēlaties, savu Stremio kontu. Profils ar PIN to pieprasa, pirms to var rediģēt."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Vali profiil selle muutmiseks. Iga profiil hoiab oma välimust, keeli, PIN-i ja valikuliselt oma Stremio kontot. PIN-iga profiil küsib seda enne muutmist."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecciona un perfil per editar-lo. Cada perfil té el seu propi aspecte, idiomes, PIN i, opcionalment, el seu propi compte de Stremio. Un perfil amb PIN el sol·licita abans que es pugui editar."
          }
        },
        "gl": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecciona un perfil para editalo. Cada perfil ten o seu propio aspecto, idiomas, PIN e opcionalmente a súa propia conta de Stremio. Un perfil con PIN solicitarallo antes de poder editalo."
          }
        },
        "eu": {
          "stringUnit": {
            "state": "translated",
            "value": "Hautatu editatzeko profil bat. Profil bakoitzak bere itxura, hizkuntzak, PIN eta hautazkoki bere Stremio kontua mantentzen ditu. PINdun profil batek eskatu egingo du editatu baino lehen."
          }
        },
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies 'n profiel om dit te wysig. Elke profiel het sy eie voorkoms, tale, PIN en opsioneel sy eie Stremio-rekening. 'n Profiel met 'n PIN vra daarvoor voor dit gewysig kan word."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Redaktə etmək üçün bir profil seçin. Hər profil öz görünüşünü, dillərini, PIN-ini və isteğe bağlı öz Stremio hesabını saxlayır. PIN-i olan profil redaktə edilməzdən əvvəl onu tələb edir."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Zgjidhni një profil për ta ndryshuar. Çdo profil ka pamjen, gjuhët, PIN-in dhe opsionalisht llogarinë e vet Stremio. Një profil me PIN kërkon atë para se të mund të ndryshohet."
          }
        },
        "is": {
          "stringUnit": {
            "state": "translated",
            "value": "Veldu prófíl til að breyta honum. Sérhver prófíll heldur eigin útliti, tungumálum, PIN og valfrjálst eigin Stremio-reikningi. Prófíll með PIN biður um hann áður en hann er hægt að breyta."
          }
        },
        "mk": {
          "stringUnit": {
            "state": "translated",
            "value": "Изберете профил за да го уредувате. Секој профил го чува сопствениот изглед, јазици, PIN и по избор сопствена Stremio сметка. Профил со PIN го бара пред да може да се уреди."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Chagua wasifu kuuhariri. Kila wasifu unaweka mwonekano wake, lugha, PIN, na kwa hiari akaunti yake ya Stremio. Wasifu wenye PIN utaiomba kabla ya kuhaririwa."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Өңдеу үшін профиль таңдаңыз. Әрбір профиль жеке сыртқы келбетін, тілдерін, PIN кодын және міндетті емес жеке Stremio тіркелгісін сақтайды. PIN бар профиль өңдеуден бұрын оны сұрайды."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Ընտրեք խմբագրելի պրոֆիլ։ Յուրաքանչյուր պրոֆիլ ունի իր տեսքը, լեզուները, PIN-ն ու կամընտիր Stremio հաշիվը։ PIN ունեցող պրոֆիլն այն կպահանջի նախքան խմբագրումը։"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "translated",
            "value": "აირჩიეთ პროფილი მის რედაქტირებისთვის. თითოეული პროფილი ინახავს საკუთარ გარეგნობას, ენებს, PIN-ს და სურვილისამებრ საკუთარ Stremio ანგარიშს. PIN-ის მქონე პროფილი მოითხოვს მის შეყვანას რედაქტირებამდე."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਸੰਪਾਦਿਤ ਕਰਨ ਲਈ ਪ੍ਰੋਫ਼ਾਈਲ ਚੁਣੋ। ਹਰ ਪ੍ਰੋਫ਼ਾਈਲ ਆਪਣੀ ਦਿੱਖ, ਭਾਸ਼ਾਵਾਂ, PIN ਅਤੇ ਵਿਕਲਪਿਕ ਤੌਰ 'ਤੇ ਆਪਣਾ Stremio ਖਾਤਾ ਰੱਖਦੀ ਹੈ। PIN ਵਾਲੀ ਪ੍ਰੋਫ਼ਾਈਲ ਸੰਪਾਦਿਤ ਕਰਨ ਤੋਂ ਪਹਿਲਾਂ ਇਹ ਮੰਗਦੀ ਹੈ।"
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "सम्पादन गर्न प्रोफाइल छनोट गर्नुहोस्। प्रत्येक प्रोफाइलले आफ्नै रूप, भाषाहरू, PIN र वैकल्पिक रूपमा आफ्नै Stremio खाता राख्छ। PIN भएको प्रोफाइलले सम्पादन गर्नु अघि त्यो माग्छ।"
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "ለማስተካከል መገለጫ ይምረጡ። እያንዳንዱ መገለጫ የራሱ ገጽታ፣ ቋንቋዎች፣ PIN፣ እና አማራጭ Stremio መለያ ይይዛሉ። PIN ያለው መገለጫ ከሚስተካከልበት በፊት ይጠይቃሉ።"
          }
        },
        "km": {
          "stringUnit": {
            "state": "translated",
            "value": "ជ្រើសប្រវត្តិរូបដើម្បីកែ។ ប្រវត្តិរូបនីមួយៗរក្សារូបរាង ភាសា PIN និងជាជម្រើស គណនី Stremio ផ្ទាល់ខ្លួន។ ប្រវត្តិរូបដែលមាន PIN នឹងស្នើវាមុនពេលអាចកែបាន។"
          }
        }
      }
    },
